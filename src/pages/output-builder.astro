---
import fs from "node:fs";
import { fileURLToPath } from "node:url";
import CaseStudyLayout from "../layouts/CaseStudyLayout.astro";
import CaseStudyFooter from "../components/CaseStudyFooter.astro";
import { FLOW_ICONS } from "../case-studies/obv3-flow-icons";
import step1Questionnaire from "../assets/step1-questionnaire.webp";
import step2ResponseCodes from "../assets/step2-response codes.webp";
import step3CreatePdf from "../assets/step3-createpdf.webp";
import step4OutputEntry from "../assets/step4-outputentry.webp";
import initialExploration from "../assets/initial-exploration.webp";
import initialVersion1 from "../assets/initialversion1.webp";
import initialVersion2 from "../assets/initialversion2.webp";
import responsemapping from "../assets/responsemapping.webp";
import "../case-studies/Obv3.css";

const EXPLORATION_IMAGES = [
  {
    image: initialExploration,
    alt: "Initial visual design exploration of the output builder canvas",
  },
  {
    image: initialVersion1,
    alt: "First visual layout builder version featuring columns and styles presets",
  },
  {
    image: initialVersion2,
    alt: "Theme presets and typography configurations editor panel mockup",
  },
];

const NAV_SECTIONS = [
  { id: "obv3-overview", label: "Overview" },
  { id: "obv3-scope", label: "Scope" },
  { id: "obv3-research", label: "Research" },
  { id: "obv3-discovery", label: "Discovery" },
  { id: "obv3-reframing", label: "Reframing" },
  { id: "obv3-datamodel", label: "Mapping Model" },
  { id: "obv3-firstversion", label: "First version" },
  { id: "obv3-concerns", label: "Concerns" },
  { id: "obv3-solution", label: "Solution" },
  { id: "obv3-impact", label: "Impact" },
  { id: "obv3-evolution", label: "Future" },
  { id: "obv3-reflection", label: "Reflection" },
];

const FLOW = [
  {
    title: "Questionnaire",
    desc: "A questionnaire is created, sometimes with fifty or more fields, and exported for output setup.",
    image: step1Questionnaire,
    alt: "Questionnaire editor with the Distance Learning Form questions listed",
  },
  {
    title: "Generate Codes",
    desc: "The system generates a unique response code for every possible answer, so a single question can have many response codes.",
    image: step2ResponseCodes,
    alt: "Exported questionnaire data showing response codes for each question",
  },
  {
    title: "PDF & code mapping",
    desc: "Required fields are recreated in PDF and the response codes are manually mapped for each.",
    image: step3CreatePdf,
    alt: "PDF builder with a response code manually entered for a selected field",
  },
  {
    title: "Upload & test",
    desc: "An output entry is created, the template is uploaded. If there are mistakes, the PDF is edited, upload again. This will repeat until everything is right.",
    image: step4OutputEntry,
    alt: "Output entry screen for uploading and configuring the Distance Learning Contract PDF",
  },
];

// Figures are dropped into public/assets/output-builder/ as they get produced.
// Render only what exists so a missing file never ships as a broken image.
const hasAsset = (p: string) =>
  fs.existsSync(fileURLToPath(new URL(`../../public${p}`, import.meta.url)));

const V1_FIGURES = [
  {
    src: "/assets/output-builder/v1-field-picker.png",
    alt: "First version of the output builder showing form fields imported by name, a builder style toggle, and a layout picker",
    caption:
      "v1. Fields imported by name, with a builder style toggle and a layout picker.",
  },
  {
    src: "/assets/output-builder/v1-section-controls.png",
    alt: "First version section controls panel with column count, linked and unlinked padding, and column gap settings",
    caption:
      "v1. Granular section controls: columns, linked and unlinked padding, column gap.",
  },
  {
    src: "/assets/output-builder/v1-theme.png",
    alt: "First version theme panel with colour swatches and typography controls, close to a full design tool",
    caption:
      "v1. Theme, colour, and typography controls. Close to a full design tool.",
  },
];

const LEGACY_FIGURE = {
  src: "/assets/output-builder/legacy-output-flow.webp",
  alt: "Diagram of the legacy output flow, showing a form's output pointing at a template built in a separate PDF tool and pasted back field by field",
  caption:
    "The legacy path. A form's output pointed at a template built in a separate PDF tool, then pasted back field by field. The notes mark where the manual work lived.",
};

const CONSTRAINTS_FIGURE = {
  src: "/assets/output-builder/stakeholder-constraints.png",
  alt: "Annotated screen of the initial builder exploration with consolidated stakeholder feedback marked across it",
  caption:
    "The consolidated feedback on the initial exploration, gathered from across the teams. Limited editability with a standard layout, how simple and complex fields should format, and two questions the teams had not settled: whether a multiple choice answer should show the selected answer only or all options, and whether fields should sit in one column or two.",
};

const CONCERNS = [
  {
    team: "Stakeholders",
    worry:
      "The drag & drop will confuse the admins. Not everyone using this will be technical.",
    color: "yellow",
    outcome:
      "I kept a manual way to add fields along with drag and drop. The visual builder became the default while the PDF route was still retained.",
  },
  {
    team: "Engineers",
    worry:
      "An open ended layout builder will be painful to build and worse to maintain",
    color: "blue",
    outcome:
      "I narrowed the customization to a small set of choices that still covered the variation organizations needed.",
  },
  {
    team: "Backend engineers",
    worry: "The new response mapping will be a challenge to implement",
    color: "purple",
    outcome:
      "I worked with the frontend engineers to confirm the mapping could be handled entirely on the frontend, with little to no extra backend work.",
  },
  {
    team: "Sales and support",
    worry:
      "Customers keep asking why implementation takes so long. They will love this!",
    color: "green",
    outcomeLabel: "What it told me",
    outcome:
      "The people closest to the customer already knew it was worth fixing.",
  },
];

const FEATURES = [
  {
    title: "Automated code mapping",
    body: "Users select form questions from a list using an interface that focused on what they are trying to do, not how the system is doing it. The system handles response codes automatically in the backend.",
    helps: [
      "Less cognitive load",
      "No memorisation of codes",
      "Fewer mapping errors",
      "Easier for new users to pick up",
    ],
    videoPath: "/assets/output-builder/work-with-data.mp4",
    duration: "0:17",
    caption:
      "Picking form questions from a plain-language list; the matching response codes are wired up automatically in the background, never shown to the user.",
  },
  {
    title: "Visual builder",
    body: "Template creation is now moved entirely inside the product. A visual builder without the bloated functions of a PDF tool is built within the product.",
    helps: [
      "Users can now see the output as they build",
      "No need to switch between the app and PDF tools",
      "Instant updates",
    ],
    videoPath: "/assets/output-builder/drag-and-drop.mp4",
    duration: "0:11",
    caption:
      "Dragging fields onto the canvas and watching the output update live as the template is built, all inside the product.",
  },
  {
    title: "Flexible Customizations",
    body: "Users can now adjust layouts and styling easily. Enough control to handle real variation without adding a new learning curve. System handles the column presentation by itself.",
    helps: [
      "Simple yet flexible customisation",
      "The system decides the layout, so users do not have to",
      "No need for external PDF tools",
    ],
    videoPath: "/assets/output-builder/flexible-customization.mp4",
    duration: "0:13",
    caption:
      "Adjusting layout and styling from a small set of controls; the system re-flows the columns on its own.",
  },
  {
    title: "Smart Organizational Defaults",
    body: "Most organizations were rebuilding output templates with similar headers and layouts from scratch every time. Predefined org defaults allows users to start from a default template and only work with the form fields.",
    helps: [
      "Faster setup",
      "Reduces repetitive work",
      "Ensures consistency",
      "Better control for organizations",
    ],
    videoPath: "/assets/output-builder/smart-defaults.mp4",
    duration: "0:19",
    caption:
      "Starting from a saved organization default and filling in only the form fields, instead of rebuilding headers and layout each time.",
  },
];

const chevronSvg =
  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9" /></svg>';

const checkSvg =
  '<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 8.5 6.5 12 13 5" /></svg>';
const previousSvg =
  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6" /></svg>';
const nextSvg =
  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6" /></svg>';
const pauseSvg =
  '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><rect x="6" y="5" width="4" height="14" rx="1" /><rect x="14" y="5" width="4" height="14" rx="1" /></svg>';
const playSvg =
  '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5.2v13.6a1 1 0 0 0 1.53.85l10.5-6.8a1 1 0 0 0 0-1.7l-10.5-6.8A1 1 0 0 0 8 5.2Z" /></svg>';
const fullscreenSvg =
  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 3 21 3 21 9" /><polyline points="9 21 3 21 3 15" /><line x1="21" y1="3" x2="14" y2="10" /><line x1="3" y1="21" x2="10" y2="14" /></svg>';
---

<CaseStudyLayout
  title="Output Builder Case Study | Viknesh Vijayakumar"
  description="How Viknesh Vijayakumar reframed output template creation to remove a manual mapping step, cutting a 2 to 3 day engineering task down to hours."
  ogImage="/assets/output-builder.webp"
>
  <div
    class="obv3-overlay"
    role="dialog"
    aria-modal="true"
    aria-label="Output Builder case study"
  >
    <div class="obv3-topbar">
      <a class="obv3-back" href="/" aria-label="Back to the portfolio">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
        <span>Back</span>
      </a>
      <div class="obv3-topbar__title">
        <span class="obv3-topbar__eyebrow">Empyra · 2024</span>
        <span class="obv3-topbar__name">Output Builder</span>
      </div>
    </div>

    <nav class="obv3-sidenav" aria-label="Sections">
      {
        NAV_SECTIONS.map((s) => (
          <a href={`#${s.id}`} class={s.id === "obv3-hero" ? "is-active" : ""}>
            {s.label}
          </a>
        ))
      }
    </nav>

    <div class="obv3-scroll">
      <section id="obv3-hero" class="obv3-hero">
        <div class="obv3-hero__inner">
          <div class="obv3-hero__main">
            <div class="obv3-hero__lede">
              <h1 class="obv3-hero__title">
                Cutting template creation from <em>days → hours</em>
              </h1>
              <p class="obv3-hero__desc">
                Reframing a document generation workflow to remove a 2 to 3 day
                engineering bottleneck.
              </p>
              <div class="obv3-scroll-hint">Scroll to explore</div>
            </div>
            <div class="obv3-hero__meta">
              <div class="obv3-meta-item">
                <span class="obv3-meta-label">Role</span><span
                  class="obv3-meta-val">Solo Designer</span
                >
              </div>
              <div class="obv3-meta-item">
                <span class="obv3-meta-label">Outcomes</span><span
                  class="obv3-meta-val">90% Faster</span
                >
              </div>
              <div class="obv3-meta-item">
                <span class="obv3-meta-label">Type</span><span
                  class="obv3-meta-val">Workflow Redesign</span
                >
              </div>
              <div class="obv3-meta-item">
                <span class="obv3-meta-label">Timeline</span><span
                  class="obv3-meta-val">4 months</span
                >
              </div>
              <div class="obv3-meta-item">
                <span class="obv3-meta-label">Skills</span><span
                  class="obv3-meta-val"
                  >Systems design, workflow redesign, feasibility, cross
                  functional alignment</span
                >
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="obv3-overview" class="obv3-section obv3-section--overview">
        <div class="obv3-section__inner">
          <div class="obv3-section__number">01<span>Overview</span></div>
          <div>
            <h2 class="obv3-heading">
              Days of engineering behind every document
            </h2>
            <p class="obv3-body">
              Organizations on the platform use forms to collect student data
              and generate official form outputs. These outputs used a PDF
              template containing the form fields and uploaded to the system.
              User responses got filled into it automatically when they
              submitted a form.
            </p>
            <p class="obv3-body">
              But the workflow behind it required an engineer to recreate the
              form layout in external PDF tools and do the data mapping manually
              into the template, resulting in multiple validation cycles and
              back and forth before the template reached production.
            </p>
            <p class="obv3-body">
              This case study presents my design process behind creating a
              modern output builder that reduced template creation time from
              days to hours.
            </p>
          </div>
        </div>
      </section>

      <section id="obv3-scope" class="obv3-section obv3-section--overview">
        <div class="obv3-section__inner">
          <div class="obv3-section__number">02<span>Scope</span></div>
          <div>
            <h2 class="obv3-heading">
              Deconstructing the problem space and execution scope
            </h2>
            <p class="obv3-body">
              Most of the work went into understanding the legacy workflow and
              designing the builder around what the system and the teams could
              support. This case study covers the output builder, one module of
              a form ecosystem I designed end to end.
            </p>

            <div class="obv3-scope-grid">
              <div class="obv3-scope-card">
                <h3 class="obv3-scope-card__title">Observation</h3>
                <ul class="obv3-scope-card__list">
                  <li>Workflow mapping</li>
                  <li>Legacy screen audit</li>
                  <li>Template and code teardown</li>
                  <li>Engineer walkthroughs</li>
                  <li>Implementation team interview</li>
                </ul>
              </div>

              <div class="obv3-scope-card">
                <h3 class="obv3-scope-card__title">Analysis</h3>
                <ul class="obv3-scope-card__list">
                  <li>Response code counting</li>
                  <li>Obsolete feature tracing</li>
                  <li>Feature carry over decisions</li>
                  <li>Problem reframing</li>
                </ul>
              </div>

              <div class="obv3-scope-card">
                <h3 class="obv3-scope-card__title">Validation</h3>
                <ul class="obv3-scope-card__list">
                  <li>Cross client template review</li>
                  <li>Technical feasibility check</li>
                  <li>PoC with engineering</li>
                  <li>Stakeholder review</li>
                </ul>
              </div>

              <div class="obv3-scope-card">
                <h3 class="obv3-scope-card__title">Implementation</h3>
                <ul class="obv3-scope-card__list">
                  <li>Design system reuse</li>
                  <li>Builder interaction design</li>
                  <li>Preset and constraint scoping</li>
                  <li>Handoff specs</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="obv3-research" class="obv3-section obv3-section--contrast">
        <div class="obv3-section__inner">
          <div class="obv3-section__number">03<span>Research</span></div>
          <div>
            <h2 class="obv3-heading">
              Learning the work from the people who did it
            </h2>
            <p class="obv3-body">
              Before I designed anything, I spent time researching how this work
              was actually done. I mapped the full workflow across users,
              admins, engineers, and the system dependencies between them, to
              understand where effort was actually going and who was affected by
              it the most. I audited the legacy output setup screen by screen,
              and opened existing templates and their response code exports to
              see exactly how a finished output was wired.
            </p>
            <section
              class="obv3-flow-container"
              aria-label="Legacy output workflow"
              data-flow-carousel
            >
              <div
                class="obv3-flow-tabs"
                role="tablist"
                aria-label="Workflow steps"
              >
                {
                  FLOW.map((f, i) => (
                    <button
                      class:list={["obv3-flow-tab", { "is-active": i === 0 }]}
                      type="button"
                      role="tab"
                      id={`obv3-flow-tab-${i}`}
                      aria-controls={`obv3-flow-panel-${i}`}
                      aria-selected={i === 0 ? "true" : "false"}
                      tabindex={i === 0 ? "0" : "-1"}
                      data-flow-tab
                    >
                      <span
                        class="obv3-flow-icon-wrap"
                        aria-hidden="true"
                        set:html={FLOW_ICONS[i] ?? FLOW_ICONS[0]}
                      />
                      <span class="obv3-flow-tab__copy">
                        <span class="obv3-flow-eyebrow">
                          Step {String(i + 1).padStart(2, "0")}
                        </span>
                        <span class="obv3-flow-title">{f.title}</span>
                      </span>
                      <span
                        class="obv3-flow-tab__progress"
                        aria-hidden="true"
                      />
                    </button>
                  ))
                }
              </div>
              <div class="obv3-flow-panels">
                {
                  FLOW.map((f, i) => (
                    <div
                      class:list={["obv3-flow-panel", { "is-active": i === 0 }]}
                      id={`obv3-flow-panel-${i}`}
                      role="tabpanel"
                      aria-labelledby={`obv3-flow-tab-${i}`}
                      aria-describedby={`obv3-flow-desc-${i}`}
                      hidden={i !== 0}
                      data-flow-panel
                    >
                      <p id={`obv3-flow-desc-${i}`} class="obv3-flow-status">
                        {f.desc}
                      </p>
                      <div class="obv3-flow-panel__media">
                        <img
                          class="obv3-flow-panel__image"
                          src={f.image.src}
                          width={f.image.width}
                          height={f.image.height}
                          alt={`${f.alt}. Step ${i + 1}: ${f.desc}`}
                          loading={i === 0 ? "eager" : "lazy"}
                          decoding="async"
                          data-lightbox-trigger
                          style="cursor: pointer;"
                        />
                        <button
                          type="button"
                          class="cd-media-maximize"
                          aria-label="Maximize image"
                          title="Maximize image"
                          data-lightbox-trigger
                          set:html={fullscreenSvg}
                        />
                      </div>
                    </div>
                  ))
                }
              </div>
              <p class="obv3-flow-status" aria-live="polite">
                Showing step 1 of {FLOW.length}
              </p>
            </section>
            <p class="obv3-body">
              The people building these templates were the engineers themselves.
              So rather than running a formal study with unfamiliar
              participants, I worked alongside the people who lived inside this
              workflow every day.
            </p>
            <p
              class="obv3-body"
              style={hasAsset(LEGACY_FIGURE.src) ? "" : "margin-bottom:0"}
            >
              I interviewed the implementation team manager whose team built
              these outputs, to understand what they needed from a better tool.
              Then I had the engineers walk me through building a form and
              mapping its codes, step by step, the way they did it on a normal
              day. This gave me a clear picture of what should carry over to the
              new builder and what could be dropped.
            </p>
            {
              hasAsset(LEGACY_FIGURE.src) && (
                <figure class="obv3-figure">
                  <img
                    src={LEGACY_FIGURE.src}
                    alt={LEGACY_FIGURE.alt}
                    loading="lazy"
                    decoding="async"
                    data-lightbox-trigger
                    style="cursor: pointer;"
                  />
                  <button
                    type="button"
                    class="cd-media-maximize"
                    aria-label="Maximize image"
                    title="Maximize image"
                    data-lightbox-trigger
                    set:html={fullscreenSvg}
                  />
                  <figcaption>{LEGACY_FIGURE.caption}</figcaption>
                </figure>
              )
            }
          </div>
        </div>
      </section>

      <section id="obv3-discovery" class="obv3-section obv3-section--overview">
        <div class="obv3-section__inner">
          <div class="obv3-section__number">04<span>Discovery</span></div>
          <div>
            <h2 class="obv3-heading">Where effort was actually being spent</h2>
            <p class="obv3-body">
              I found that most of the time was going into mapping the response
              codes into the template rather than designing it.
            </p>
            <p class="obv3-body">
              Every answer carried its own response code. The example form below
              was one of the most common, and it had twenty three questions, but
              forty five codes to map. Every form requires at least one output
              with all the fields mapped by default, and larger forms ended up
              requiring hundreds of mappings per form.
            </p>
            <p class="obv3-body">
              Missing or mistyping a single code meant the field would not get
              filled, or worse, wrong information would be filled in on an
              official document.
            </p>

            <figure class="obv3-figure">
              <img
                src={responsemapping.src}
                width={responsemapping.width}
                height={responsemapping.height}
                alt="Response mapping for one form: 23 questions expand into 45 response codes, since every possible answer needs its own code"
                loading="lazy"
                decoding="async"
                data-lightbox-trigger
                style="cursor: pointer;"
              />
              <button
                type="button"
                class="cd-media-maximize"
                aria-label="Maximize image"
                title="Maximize image"
                data-lightbox-trigger
                set:html={fullscreenSvg}
              />
            </figure>

            <p class="obv3-body" style="margin-top:24px">
              The audit also turned up things nobody remembered the reason for.
              One option, File Category, had been added for a single client and
              carried through every build since, though no one used it and no
              one could explain what it did. When I traced it, it turned out to
              organize the generated PDFs inside the system. Since the new model
              does not store PDFs at all, the option had no reason to exist, and
              it was dropped.
            </p>
          </div>
        </div>
      </section>
      <section id="obv3-reframing" class="obv3-section obv3-section--overview">
        <div class="obv3-section__inner">
          <div class="obv3-section__number">05<span>Reframing</span></div>
          <div>
            <h2 class="obv3-heading">
              From building a PDF editor to redesigning the workflow
            </h2>
            <p class="obv3-body">The original requirement was simple:</p>
            <blockquote class="obv3-blockquote">
              “How might we make PDF creation easier?”
            </blockquote>
            <p class="obv3-body">
              But once I realised that it was the manual mapping that was taking
              up the engineer's time, I rephrased the requirement:
            </p>
            <blockquote class="obv3-blockquote">
              “How might we remove manual mapping, so the engineers just build
              the layout?”
            </blockquote>
            <p class="obv3-body">
              This reframing simplified the scope from building a brand new PDF
              editor inside the platform to a workflow redesign. By removing
              unnecessary steps, we would make the complex manual workflow
              simple. The challenge was to build it without affecting the legacy
              backend, and to build on the mental models users already
              understood.
            </p>
          </div>
        </div>
      </section>

      <section id="obv3-datamodel" class="obv3-section obv3-section--overview">
        <div class="obv3-section__inner">
          <div class="obv3-section__number">06<span>Mapping Model</span></div>
          <div>
            <h2 class="obv3-heading">
              Automating the mapping model before the interface
            </h2>
            <p class="obv3-body">
              There are two parts to the output builder: a mapping layer and the
              layout builder. PDF was the container which had both of these
              layers packed together.
            </p>
            <p class="obv3-body">
              If layout is built into the system, why keep PDF as the container
              at all? Can't the mapping data be stored separately as data
              bindings? I had worked on similar mapping systems before and
              immediately thought of JSON as viable alternative.
            </p>
            <p class="obv3-body">
              That was my theory, so I went and checked it. I reviewed the
              output templates built for several clients over the period and
              found that the design of them all followed a simple layout
              pattern, repetitive enough for the system to generate, while the
