<script>
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  // Shared wiring for both carousels: 10s autoplay (paused on hover, focus, or
  // an open lightbox — re-checked live each tick so a stale flag can't strand
  // it), horizontal swipe, in-view gating, and reduced-motion. `advance(delta)`
  // is the only thing each carousel supplies. Returns `start` so click/keyboard
  // handlers can restart the timer after a manual move.
  const autoCarousel = (
    carousel: HTMLElement,
    advance: (delta: number) => void,
  ) => {
    let intervalId: number | undefined;
    let isVisible = false;

    const start = () => {
      if (intervalId !== undefined) window.clearInterval(intervalId);
      intervalId = undefined;
      if (!isVisible || reduceMotion.matches) return;
      intervalId = window.setInterval(() => {
        if (
          carousel.matches(":hover") ||
          carousel.contains(document.activeElement) ||
          document.querySelector(".cd-lightbox.is-open")
        )
          return;
        advance(1);
      }, 10000);
    };

    let touchStartX = 0;
    carousel.addEventListener(
      "touchstart",
      (e) => {
        touchStartX = e.changedTouches[0].screenX;
      },
      { passive: true },
    );
    carousel.addEventListener(
      "touchend",
      (e) => {
        start();
        const dx = e.changedTouches[0].screenX - touchStartX;
        if (dx < -50) advance(1);
        if (dx > 50) advance(-1);
      },
      { passive: true },
    );

    new IntersectionObserver(
      ([entry]) => {
        isVisible = entry.isIntersecting;
        start();
      },
      { threshold: 0.25 },
    ).observe(carousel);

    reduceMotion.addEventListener("change", start);
    return start;
  };

  const carousels = document.querySelectorAll<HTMLElement>(
    "[data-flow-carousel]",
  );
  carousels.forEach((carousel) => {
    const tabs = Array.from(
      carousel.querySelectorAll<HTMLButtonElement>("[data-flow-tab]"),
    );
    const panels = Array.from(
      carousel.querySelectorAll<HTMLElement>("[data-flow-panel]"),
    );
    const status = carousel.querySelector<HTMLElement>(".obv3-flow-status");
    let activeIndex = 0;

    const update = (index: number, moveFocus = false) => {
      activeIndex = (index + tabs.length) % tabs.length;

      tabs.forEach((tab, tabIndex) => {
        const selected = tabIndex === activeIndex;
        tab.classList.toggle("is-active", selected);
        tab.setAttribute("aria-selected", String(selected));
        tab.tabIndex = selected ? 0 : -1;

        if (selected) {
          const fill = tab.querySelector<HTMLElement>(
            ".obv3-flow-tab__progress",
          );
          if (fill) {
            fill.style.animation = "none";
            void fill.offsetWidth;
            fill.style.animation = "";
          }
        }
      });

      panels.forEach((panel, panelIndex) => {
        const selected = panelIndex === activeIndex;
        panel.classList.toggle("is-active", selected);
        panel.hidden = !selected;
      });

      if (status) {
        status.textContent = `Showing step ${activeIndex + 1} of ${tabs.length}`;
      }

      if (moveFocus) tabs[activeIndex].focus();
    };

    const start = autoCarousel(carousel, (delta) =>
      update(activeIndex + delta),
    );

    tabs.forEach((tab, index) => {
      tab.addEventListener("click", () => {
        update(index);
        start();
      });

      tab.addEventListener("keydown", (event) => {
        const nextIndex =
          event.key === "ArrowRight" || event.key === "ArrowDown"
            ? activeIndex + 1
            : event.key === "ArrowLeft" || event.key === "ArrowUp"
              ? activeIndex - 1
              : event.key === "Home"
                ? 0
                : event.key === "End"
                  ? tabs.length - 1
                  : null;

        if (nextIndex === null) return;
        event.preventDefault();
        update(nextIndex, true);
        start();
      });
    });
  });

  // Exploration Mockups Carousel
  const explorationCarousels = document.querySelectorAll<HTMLElement>(
    "[data-exploration-carousel]",
  );
  explorationCarousels.forEach((carousel) => {
    const panels = Array.from(
      carousel.querySelectorAll<HTMLElement>("[data-exploration-panel]"),
    );
    const prev = carousel.querySelector<HTMLButtonElement>(
      "[data-exploration-previous]",
    );
    const next = carousel.querySelector<HTMLButtonElement>(
      "[data-exploration-next]",
    );
    let activeIndex = 0;

    const update = (index: number) => {
      activeIndex = (index + panels.length) % panels.length;

      panels.forEach((panel, panelIndex) => {
        const selected = panelIndex === activeIndex;
        panel.classList.toggle("is-active", selected);
        panel.hidden = !selected;
      });
    };

    const start = autoCarousel(carousel, (delta) =>
      update(activeIndex + delta),
    );

    prev?.addEventListener("click", () => {
      update(activeIndex - 1);
      start();
    });

    next?.addEventListener("click", () => {
      update(activeIndex + 1);
      start();
    });
  });
</script>
