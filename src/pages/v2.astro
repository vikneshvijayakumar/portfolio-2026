---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import "../styles/v2.css";

import profileImg from "../assets/profile.webp";
import outputBuilderImg from "../assets/output-builder.webp";
import clinicalDocImg from "../assets/clinical-documentation.webp";
import aiStylistImg from "../assets/aistylist.webp";
import formTakingImg from "../assets/form-taking.webp";
import upworkBadge from "../assets/Upwork-TopRated-Badge.svg";
import googleUxBadge from "../assets/google-ux.webp";

const LINKEDIN = "https://www.linkedin.com/in/vikneshvijayakumar/";
const DRIBBBLE = "https://dribbble.com/vikneshvijayakumar";
const RESUME =
  "https://drive.google.com/file/d/16Iyt5Sfy_c8Jv3_tKE_pivnKhpe1QpYo/view?usp=sharing";

const works = [
  {
    href: "/output-builder",
    image: outputBuilderImg,
    meta: "Edtech · 2025",
    title: "Days of template work, done in hours",
    blurb:
      "A visual builder that replaced engineer-driven PDF mapping. Now fully self-serve.",
    tag: "90% faster",
  },
  {
    href: "/clinical-documentation",
    image: clinicalDocImg,
    meta: "Healthcare AI · 2021",
    title: "AI-native clinical notes, before AI was a thing",
    blurb:
      "A realtime platform that listens to the visit and writes the report, from intake to AI trainer.",
    tag: "30+ modules",
  },
  {
    href: "/ai-stylist",
    image: aiStylistImg,
    meta: "Fashion AI · 2025",
    title: "Getting an AI stylist out of its own way",
    blurb:
      "Value first, paywall later. Users see what the AI can do before they're asked to commit.",
    tag: "Faster first recommendation",
  },
  {
    href: "/form-taking",
    image: formTakingImg,
    meta: "Edtech · 2025",
    title: "One enrollment flow instead of five",
    blurb:
      "Legacy .NET forms embedded inside a guided, mobile-first React shell.",
    tag: "Zero lost users",
  },
];

const experience = [
  {
    role: "Product Designer",
    company: "Empyra",
    period: "Aug 2023 - Jan 2026",
    summary:
      "Led redesign of complex admin workflows during a .NET-to-React migration. Managed two Figma design systems and WCAG accessibility across the product.",
  },
  {
    role: "Freelance Product Designer",
    company: "Upwork · Top Rated",
    period: "Apr 2023 - Jul 2023",
    summary:
      "Delivered MVPs for AI and B2B startups globally while balancing production speed with product quality.",
  },
  {
    role: "Founding / Lead Product Designer",
    company: "AmbientOne",
    period: "Mar 2015 - Jul 2023",
    summary:
      "Designed AI-powered healthcare products, led a seven-person design team, and built standards for shipping at scale.",
  },
  {
    role: "UI / Graphic Designer",
    company: "Spiceblue",
    period: "2014 - 2015",
    summary:
      "Designed a leave management workflow for Kissflow, improving usability for day-to-day administrative tasks.",
  },
];

const principles = [
  {
    title: "Fix the workflow first",
    copy: "A pretty interface can't save a broken process. I remove friction before I draw a screen.",
  },
  {
    title: "Design with engineering",
    copy: "I write HTML and CSS, so I spec what can actually be built. Nobody has to translate.",
  },
  {
    title: "Consistent, everywhere",
    copy: "One decision, applied everywhere. Strict 4px grid, no one-off exceptions.",
  },
  {
    title: "Accessibility is the baseline",
    copy: "Built in from the start, not audited at the end. Edge cases make the whole product better.",
  },
];

const marqueeItems = [
  "Enterprise UX",
  "Healthcare AI",
  "Edtech",
  "Design Systems",
  "AI Prototyping",
  "B2B SaaS",
];

const markLeft =
  "m23.475 4 4.463 3.016v.61L16.362 24.663l-.518.353h-8.73L5.077 28h-.615L0 24.984v-.61L13.84 4h.614l4.462 3.016v.61l-9.83 14.47v2.182L22.861 4h.614Z";
const markRight =
  "M41.538 4 46 7.016v.61L34.424 24.663l-.517.353h-8.73L23.138 28h-.614l-4.463-3.016v-.61L31.902 4h.614l4.462 3.016v.61l-9.83 14.47v2.182L40.923 4h.615Z";
---

<Layout
  title="Selected Product Design Work | Viknesh Vijayakumar"
  description="Selected product design work across healthcare AI, edtech, and B2B SaaS by Viknesh Vijayakumar."
  ogImage="/assets/profile.webp"
  pageClass="v2 v2-page"
>
    <header class="v2-nav">
      <a href="#top" aria-label="Back to top">
        <svg class="v2-nav__mark" viewBox="0 0 46 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path fill="currentColor" d={markLeft}></path>
          <path fill="currentColor" d={markRight}></path>
        </svg>
      </a>
      <nav class="v2-nav__links" aria-label="Primary">
        <a href="#work">Work</a>
        <a href="#experience">Experience</a>
        <a href="#about">About</a>
        <a class="v2-nav__cta" href="mailto:hello@viknesh.me">Email</a>
      </nav>
    </header>

    <main id="top">
      <!-- Hero -->
      <section class="v2-hero">
        <div class="v2-hero__watermark" aria-hidden="true">
          <svg viewBox="0 0 46 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path fill="currentColor" d={markLeft}></path>
            <path fill="currentColor" d={markRight}></path>
          </svg>
        </div>
        <p class="v2-hero__eyebrow v2-load" style="--d: 0.05s">Open for opportunities</p>
        <h1 class="v2-hero__title v2-load" style="--d: 0.15s">
          Complex software, made to feel <em>simple.</em>
        </h1>
        <div class="v2-hero__row">
          <p class="v2-hero__sub v2-load" style="--d: 0.3s">
            <strong>Viknesh Vijayakumar</strong>, Lead Product Designer. 12 years
            across healthcare AI, edtech, and B2B SaaS.
          </p>
          <div class="v2-hero__actions v2-load" style="--d: 0.4s">
            <a class="v2-btn v2-btn--primary" href="#work">See the work</a>
            <a class="v2-btn" href={RESUME} target="_blank" rel="noreferrer">Resume</a>
          </div>
        </div>
      </section>

      <!-- Marquee -->
      <div class="v2-marquee" aria-label={marqueeItems.join(", ")}>
        <div class="v2-marquee__track">
          {[false, true].map((hidden) => (
            <div class="v2-marquee__row" aria-hidden={hidden}>
              {marqueeItems.map((item) => (
                <span class="v2-marquee__item">
                  <svg viewBox="0 0 46 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path fill="currentColor" d={markLeft}></path>
                    <path fill="currentColor" d={markRight}></path>
                  </svg>
                  {item}
                </span>
              ))}
            </div>
          ))}
        </div>
      </div>

      <!-- Work: sticky stack -->
      <section class="v2-work" id="work">
        <h2 class="v2-section__title v2-reveal">
          Selected work <span>/ high-stakes, everyday workflows</span>
        </h2>
        <div class="v2-stack">
          {works.map((work) => (
            <article class="v2-card">
              <div>
                <p class="v2-card__meta v2-mono">{work.meta}</p>
                <h3 class="v2-card__title">{work.title}</h3>
                <p class="v2-card__blurb">{work.blurb}</p>
                <p class="v2-card__tag">{work.tag}</p>
                <div>
                  <a class="v2-card__link" href={work.href}>
                    Read case study
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M7 17 17 7M8 7h9v9"></path>
                    </svg>
                  </a>
                </div>
              </div>
              <a class="v2-card__media" href={work.href} tabindex="-1" aria-hidden="true">
                <Image src={work.image} alt="" loading="lazy" />
              </a>
            </article>
          ))}
        </div>
      </section>

      <!-- Stats -->
      <section class="v2-section">
        <div class="v2-stats">
          <div class="v2-stat v2-reveal">
            <strong>12+</strong>
            <span>years in product design</span>
          </div>
          <div class="v2-stat v2-reveal" style="--d: 0.08s">
            <strong>30+</strong>
            <span>modules shipped in one platform</span>
          </div>
          <div class="v2-stat v2-reveal" style="--d: 0.16s">
            <strong>1000+</strong>
            <span>screens designed for clinical AI</span>
          </div>
          <div class="v2-stats__badges v2-reveal" style="--d: 0.24s">
            <a href="https://www.upwork.com/freelancers/~0124077c8ba1055975" target="_blank" rel="noreferrer">
              <img src={upworkBadge.src} alt="Upwork Top Rated" width="140" height="40" loading="lazy" />
            </a>
            <a href="https://coursera.org/verify/professional-cert/7QG5LZC7FDAB" target="_blank" rel="noreferrer">
              <Image class="v2-stats__google" src={googleUxBadge} alt="Google UX Design Certificate" width="112" loading="lazy" />
            </a>
          </div>
        </div>
      </section>

      <!-- Experience -->
      <section class="v2-section" id="experience">
        <h2 class="v2-section__title v2-reveal">
          Experience <span>/ startups to enterprise</span>
        </h2>
        <ol class="v2-exp">
          {experience.map((job, i) => (
            <li class="v2-reveal" style={`--d: ${i * 0.06}s`}>
              <span class="v2-mono">{job.period}</span>
              <div>
                <h3>{job.role} <span>· {job.company}</span></h3>
                <p>{job.summary}</p>
              </div>
            </li>
          ))}
        </ol>
      </section>

      <!-- Principles -->
      <section class="v2-section" id="principles">
        <h2 class="v2-section__title v2-reveal">
          How I work <span>/ four rules that survive every project</span>
        </h2>
        <div class="v2-principles">
          {principles.map((p, i) => (
            <div class="v2-principle v2-reveal" style={`--d: ${i * 0.06}s`}>
              <h3>{p.title}</h3>
              <p>{p.copy}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- About -->
      <section class="v2-section" id="about">
        <div class="v2-about">
          <div class="v2-about__photo v2-reveal">
            <Image src={profileImg} alt="Viknesh Vijayakumar" width="640" loading="lazy" />
          </div>
          <div class="v2-reveal" style="--d: 0.1s">
            <h2>Usually the only designer in the room.</h2>
            <p>
              I've spent most of my career as a sole designer, owning products
              from problem framing to delivery: clinical AI platforms,
              enrollment systems, styling apps.
            </p>
            <p>
              I use AI as a multiplier: Claude Code and Figma AI to ideate
              faster, prototype in real code, and ship the leanest thing that
              delivers the most value.
            </p>
            <div class="v2-about__actions">
              <a class="v2-btn" href={DRIBBBLE} target="_blank" rel="noreferrer">Dribbble</a>
              <a class="v2-btn" href={LINKEDIN} target="_blank" rel="noreferrer">LinkedIn</a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <!-- Footer -->
    <footer class="v2-footer">
      <h2 class="v2-footer__title v2-reveal">
        Building something<br />complex? <em>Let's talk.</em>
      </h2>
      <button class="v2-copy-email v2-reveal" style="--d: 0.1s" type="button" id="copyEmail">
        hello@viknesh.me
        <small id="copyHint">Click to copy</small>
      </button>
      <div class="v2-footer__row">
        <span>© {new Date().getFullYear()} Viknesh Vijayakumar</span>
        <nav aria-label="Social">
          <a href={LINKEDIN} target="_blank" rel="noreferrer">LinkedIn</a>
          <a href={DRIBBBLE} target="_blank" rel="noreferrer">Dribbble</a>
          <a href="https://wa.me/918148836036" target="_blank" rel="noreferrer">WhatsApp</a>
        </nav>
      </div>
    </footer>

    <script>
      // Scroll reveals
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add("in");
              io.unobserve(e.target);
            }
          }
        },
        { rootMargin: "-60px 0px" }
      );
      document.querySelectorAll(".v2-reveal").forEach((el) => io.observe(el));

      // Copy email
      const btn = document.getElementById("copyEmail");
      const hint = document.getElementById("copyHint");
      btn?.addEventListener("click", () => {
        navigator.clipboard
          ?.writeText("hello@viknesh.me")
          .then(() => {
            if (hint) hint.textContent = "Copied!";
            setTimeout(() => {
              if (hint) hint.textContent = "Click to copy";
            }, 2000);
          })
          .catch(() => {
            window.location.href = "mailto:hello@viknesh.me";
          });
      });
    </script>
</Layout>
