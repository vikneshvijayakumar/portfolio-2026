  </main>

  <!-- Copy Toast -->
  <div class="copy-toast" id="copyToast">Email copied!</div>

  <script is:inline>
    // ── Footer year ──────────────────────────────────────────────────────────
    document.getElementById("footerYear").textContent =
      new Date().getFullYear();

    // ── Mobile header: hide on scroll down, show on scroll up ────────────────
    (function () {
      var header = document.querySelector(".mobile-header");
      if (!header) return;
      var lastY = 0,
        hidden = false;
      window.addEventListener(
        "scroll",
        function () {
          var y = window.scrollY;
          if (y > lastY && y > 60 && !hidden) {
            header.style.transform = "translateY(-100%)";
            hidden = true;
          } else if (y < lastY && hidden) {
            header.style.transform = "translateY(0)";
            hidden = false;
          }
          lastY = y;
        },
        { passive: true },
      );
    })();

    // ── Scroll-based active nav highlighting ─────────────────────────────────
    var sections = document.querySelectorAll(".section[id]");
    var navLinks = document.querySelectorAll(".nav-link[data-section]");
    var mobileNavLinks = document.querySelectorAll(
      ".mobile-header__link[data-section]",
    );

    function updateActiveNav() {
      var scrollY = window.scrollY + window.innerHeight * 0.3;
      var active = null;
      sections.forEach(function (section) {
        if (section.offsetTop <= scrollY) active = section.id;
      });
      if (active) {
        navLinks.forEach(function (link) {
          link.classList.toggle("active", link.dataset.section === active);
        });
        mobileNavLinks.forEach(function (link) {
          link.classList.toggle("active", link.dataset.section === active);
        });
      }
    }
    window.addEventListener("scroll", updateActiveNav, { passive: true });
    updateActiveNav();

    // ── Globe spin ───────────────────────────────────────────────────────────
    var globeSvg = document.querySelector(".globe-svg");
    var locationLine = document.querySelector(".hero-bio--location");
    if (
      globeSvg &&
      !window.matchMedia("(prefers-reduced-motion: reduce)").matches
    ) {
      function spinGlobe() {
        var meridians = globeSvg.querySelectorAll(".globe-meridian");
        meridians.forEach(function (m) {
          var clone = m.cloneNode(true);
          m.parentNode.replaceChild(clone, m);
        });
        globeSvg.classList.add("globe-spinning");
      }
      setTimeout(spinGlobe, 600);
      if (locationLine) locationLine.addEventListener("mouseenter", spinGlobe);
    }

    // ── Mobile menu toggle ───────────────────────────────────────────────────
    var menuToggle = document.querySelector(".menu-toggle");
    var mobileMenu = document.querySelector(".mobile-menu");
    var mobileLinks = document.querySelectorAll(".mobile-menu-link");

    if (menuToggle) {
      menuToggle.addEventListener("click", function () {
        var isOpen = menuToggle.getAttribute("aria-expanded") === "true";
        menuToggle.setAttribute("aria-expanded", !isOpen);
        mobileMenu.setAttribute("aria-hidden", isOpen);
        document.body.classList.toggle("menu-open", !isOpen);
      });

      mobileLinks.forEach(function (link) {
        link.addEventListener("click", function () {
          if (link.id === "mobileMenuCopyEmail") return;
          menuToggle.setAttribute("aria-expanded", "false");
          mobileMenu.setAttribute("aria-hidden", "true");
          document.body.classList.remove("menu-open");
        });
      });
    }

    // ── Reveal load animations ───────────────────────────────────────────────
    (function () {
      var loads = document.querySelectorAll(".reveal-load");
      loads.forEach(function (el) {
        var delay = el.dataset.revealDelay || 0;
        setTimeout(function () {
          el.classList.add("is-visible");
        }, parseInt(delay));
      });
    })();

    // ── Reveal scroll animations ─────────────────────────────────────────────
    (function () {
      var scrollEls = document.querySelectorAll(".reveal-scroll");
      var observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: "0px 0px -60px 0px" },
      );
      scrollEls.forEach(function (el) {
        observer.observe(el);
      });
    })();

    // ── Sticky case study stacking effect ────────────────────────────────────
    (function () {
      var studies = document.querySelectorAll(".case-study");
      if (studies.length < 2) return;
      studies.forEach(function (card, i) {
        card.style.zIndex = i + 1;
      });

      function setStickyTops() {
        var viewH = window.innerHeight;
        for (var i = 0; i < studies.length; i++) {
          var cardH = studies[i].offsetHeight;
          studies[i].style.top =
            cardH <= viewH - 56 - 24 ? "56px" : viewH - cardH - 24 + "px";
        }
      }
      setStickyTops();
      window.addEventListener("load", setStickyTops);
      window.addEventListener("resize", setStickyTops);

      function onScroll() {
        for (var i = 0; i < studies.length - 1; i++) {
          var card = studies[i];
          var next = studies[i + 1];
          var cardRect = card.getBoundingClientRect();
          var nextRect = next.getBoundingClientRect();
          var overlap = cardRect.bottom - nextRect.top;
          var progress = Math.max(0, Math.min(1, overlap / cardRect.height));
          card.style.opacity = Math.max(0, 1 - progress).toFixed(3);
          card.style.filter =
            progress > 0.2
              ? "blur(" + (progress * 6).toFixed(1) + "px)"
              : "none";
          card.style.transform =
            "scale(" + (1 - progress * 0.07).toFixed(4) + ")";
          next.style.paddingTop =
            Math.max(0, 72 - progress * 72).toFixed(1) + "px";
        }
      }
      window.addEventListener("scroll", onScroll, { passive: true });
      onScroll();
    })();

    // ── Tilt effect on case study cards ─────────────────────────────────────
    (function () {
      var tilts = document.querySelectorAll(".case-study__tilt");
      var amp = 2;
      function lerp(a, b, t) {
        return a + (b - a) * t;
      }
      tilts.forEach(function (card) {
        var glare = card.querySelector(".tilt-glare");
        var sx = 0,
          sy = 0,
          ss = 1,
          tx = 0,
          ty = 0,
          ts = 1,
          raf = null,
          hov = false;
        function tick() {
          sx = lerp(sx, tx, 0.08);
          sy = lerp(sy, ty, 0.08);
          ss = lerp(ss, ts, 0.04);
          if (
            Math.abs(sx - tx) < 0.01 &&
            Math.abs(sy - ty) < 0.01 &&
            Math.abs(ss - ts) < 0.001 &&
            !hov
          ) {
            card.style.transform =
              "perspective(1000px) rotateX(0deg) rotateY(0deg) scale(1)";
            if (glare) glare.style.opacity = "0";
            raf = null;
            return;
          }
          card.style.transform =
            "perspective(1000px) rotateX(" +
            sx.toFixed(2) +
            "deg) rotateY(" +
            sy.toFixed(2) +
            "deg) scale(" +
            ss.toFixed(4) +
            ")";
          raf = requestAnimationFrame(tick);
        }
        card.addEventListener("mousemove", function (e) {
          var r = card.getBoundingClientRect();
          tx = -((e.clientY - r.top) / r.height - 0.5) * amp;
          ty = ((e.clientX - r.left) / r.width - 0.5) * amp;
          if (glare) {
            glare.style.background =
              "radial-gradient(circle at " +
              ((e.clientX - r.left) / r.width) * 100 +
              "% " +
              ((e.clientY - r.top) / r.height) * 100 +
              "%, rgba(255,255,255,0.056) 0%, transparent 60%)";
            glare.style.opacity = "1";
          }
          if (!raf) raf = requestAnimationFrame(tick);
        });
        card.addEventListener("mouseenter", function () {
          hov = true;
          ts = 1.01;
          card.style.transition = "none";
          if (!raf) raf = requestAnimationFrame(tick);
        });
        card.addEventListener("mouseleave", function () {
          hov = false;
          tx = 0;
          ty = 0;
          ts = 1;
          if (glare) glare.style.opacity = "0";
          if (!raf) raf = requestAnimationFrame(tick);
        });
      });
    })();

    // ── Copy email functionality ─────────────────────────────────────────────
    var EMAIL = "hello@viknesh.me";
    var toast = document.getElementById("copyToast");

    function showToast(msg) {
      toast.textContent = msg || "Email copied!";
      toast.classList.add("show");
      setTimeout(function () {
        toast.classList.remove("show");
      }, 2000);
    }

    function copyEmail(e) {
      if (e) e.preventDefault();
      navigator.clipboard.writeText(EMAIL).then(function () {
        showToast("Email copied!");
      });
    }

    var sidebarEmail = document.getElementById("sidebarCopyEmail");
    var aboutCopy = document.getElementById("aboutCopyEmail");
    var mobileCopy = document.getElementById("mobileMenuCopyEmail");
    var ctaCopy = document.getElementById("ctaCopyEmail");

    if (sidebarEmail) sidebarEmail.addEventListener("click", copyEmail);
    if (aboutCopy) aboutCopy.addEventListener("click", copyEmail);
    if (mobileCopy) mobileCopy.addEventListener("click", copyEmail);
    if (ctaCopy) ctaCopy.addEventListener("click", copyEmail);
  </script>
</Layout>
