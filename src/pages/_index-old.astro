---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";

import profileImg from "../assets/profile.webp";
import outputBuilderImg from "../assets/output-builder.webp";
import clinicalDocImg from "../assets/clinical-documentation.webp";
import aiStylistImg from "../assets/aistylist.webp";
import formTakingImg from "../assets/form-taking.webp";
import aiTranscriptionImg from "../assets/ai-transcription.webp";
import snapIntakeImg from "../assets/snapintake.webp";
const EMAIL = "hello@viknesh.me";
const LINKEDIN = "https://www.linkedin.com/in/vikneshvijayakumar/";
const DRIBBBLE = "https://dribbble.com/vikneshvijayakumar";
const WHATSAPP = "https://wa.me/918148836036";
const RESUME =
  "https://drive.google.com/file/d/16Iyt5Sfy_c8Jv3_tKE_pivnKhpe1QpYo/view?usp=sharing";
---

<Layout
  title="Viknesh Vijayakumar — Senior Product Designer"
  description="Senior product designer with 10+ years building enterprise SaaS across healthcare, AI, and edtech."
>
  <!-- Mobile Header -->
  <header class="mobile-header">
    <a href="#top" class="mobile-logo">
      <span class="logo-text">Viknesh V.</span>
    </a>
    <nav class="mobile-header__nav">
      <a href="#work" class="mobile-header__link active" data-section="work"
        >Work</a
      >
      <a
        href="#experience"
        class="mobile-header__link"
        data-section="experience">Experience</a
      >
      <a
        href="#principles"
        class="mobile-header__link"
        data-section="principles">Principles</a
      >
      <a href="#about" class="mobile-header__link" data-section="about">About</a
      >
    </nav>
    <button class="menu-toggle" aria-label="Menu" aria-expanded="false">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </header>

  <!-- Mobile Menu Overlay -->
  <div class="mobile-menu" aria-hidden="true">
    <a href="#work" class="mobile-menu-link">Work</a>
    <a href="#experience" class="mobile-menu-link">Experience</a>
    <a href="#principles" class="mobile-menu-link">Principles</a>
    <a href="#about" class="mobile-menu-link">About</a>
    <div class="mobile-menu-bottom">
      <a href={LINKEDIN} target="_blank" rel="noopener" class="mobile-menu-link"
        >LinkedIn</a
      >
      <a href="#" class="mobile-menu-link" id="mobileMenuCopyEmail">Email</a>
    </div>
  </div>

  <!-- Sidebar (Desktop) -->
  <aside class="sidebar reveal-load">
    <div class="sidebar-top">
      <a
        href="#top"
        class="sidebar-name reveal-load"
        data-reveal-delay="60"
        id="sidebarSig"
      >
        <div class="logo-sig">Viknesh V.</div>
      </a>
      <nav class="sidebar-nav">
        <a
          href="#work"
          class="nav-link active reveal-load"
          data-reveal-delay="140"
          data-section="work">Work</a
        >
        <a
          href="#experience"
          class="nav-link reveal-load"
          data-reveal-delay="180"
          data-section="experience">Experience</a
        >
        <a
          href="#principles"
          class="nav-link reveal-load"
          data-reveal-delay="220"
          data-section="principles">Principles</a
        >
        <a
          href="#about"
          class="nav-link reveal-load"
          data-reveal-delay="260"
          data-section="about">About</a
        >
      </nav>
    </div>
    <div class="sidebar-bottom">
      <a
        href={LINKEDIN}
        target="_blank"
        rel="noopener"
        class="sidebar-external reveal-load"
        data-reveal-delay="360">LinkedIn</a
      >
      <a
        href="#"
        class="sidebar-external sidebar-email reveal-load"
        data-reveal-delay="400"
        id="sidebarCopyEmail">Email</a
      >
    </div>
  </aside>

  <!-- Main Content -->
  <main class="content" id="top">
    <!-- Hero Section -->
    <section id="hero" class="section section--hero">
      <div class="centered">
        <p class="hero-eyebrow reveal-load" data-reveal-delay="60">
          <span class="hero-dot"></span> Open for opportunities
        </p>

        <h1 class="hero-name shiny-hover reveal-load" data-reveal-delay="100">
          I make complex enterprise software feel simple
        </h1>

        <div class="hero-bio reveal-load" data-reveal-delay="200">
          <p>
            Senior Product Designer. 10+ years across healthcare AI, edtech, and
            B2B SaaS, usually the only designer in the room. I take
            systems with confusing workflows and technical constraints and turn
            them into interfaces people can actually use.
          </p>
          <p class="hero-bio--location">
            <span class="globe-wrap">
              <svg
                class="globe-svg"
                viewBox="0 0 22 22"
                width="22"
                height="22"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <circle
                  cx="11"
                  cy="11"
                  r="10"
                  stroke="#6B6666"
                  stroke-width="1.5"></circle>
                <line
                  x1="1"
                  y1="11"
                  x2="21"
                  y2="11"
                  stroke="#6B6666"
                  stroke-width="1.5"></line>
                <ellipse
                  class="globe-meridian"
                  cx="11"
                  cy="11"
                  rx="10"
                  ry="10"
                  stroke="#6B6666"
                  stroke-width="1.5"
                  vector-effect="non-scaling-stroke"></ellipse>
                <ellipse
                  class="globe-meridian m2"
                  cx="11"
                  cy="11"
                  rx="10"
                  ry="10"
                  stroke="#6B6666"
                  stroke-width="1.5"
                  vector-effect="non-scaling-stroke"></ellipse>
              </svg>
            </span>
            <span>Chennai, India. Available remotely.</span>
          </p>
        </div>

        <div class="hero-actions reveal-load" data-reveal-delay="260">
          <a
            href="https://drive.google.com/file/d/16Iyt5Sfy_c8Jv3_tKE_pivnKhpe1QpYo/view?usp=drive_link"
            class="case-study__btn"
          >
            <span>Download Resume</span>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
              ><path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M5.75 11C5.33579 11 5 11.3358 5 11.75C5 12.1642 5.33579 12.5 5.75 12.5L16.6487 12.5L13.1738 16.2698C12.9087 16.5881 12.9517 17.061 13.2699 17.3261C13.5881 17.5913 14.061 17.5483 14.3262 17.2301L18.8262 12.2301C19.0579 11.952 19.0579 11.548 18.8262 11.2698L14.3262 6.26984C14.061 5.95163 13.5881 5.90864 13.2699 6.17382C12.9517 6.43899 12.9087 6.91191 13.1738 7.23012L16.6487 11L5.75 11Z"
                fill="#FFF1F2"></path></svg
            >
          </a>
        </div>

        <!-- Proof Strip -->
        <div class="proof-strip reveal-load" data-reveal-delay="320">
          <div class="proof-stat">
            <strong>10+</strong>
            <span>years in product design</span>
          </div>
          <div class="proof-stat">
            <strong>30+</strong>
            <span>modules shipped in one platform</span>
          </div>
          <div class="proof-stat">
            <strong>1000+</strong>
            <span>screens designed for clinical AI</span>
          </div>
        </div>

        <!-- Case Studies -->
        <div class="case-studies section" id="work">
          <!-- Project 1 -->
          <div class="case-study">
            <div class="case-study__header">
              <div class="case-study__text">
                <h2 class="case-study__title shiny-hover">
                  Eliminating PDF bottlenecks with a visual builder
                </h2>
                <p class="case-study__caption">
                  <span class="case-study__caption-desc"
                    >Empyra &middot; 90% faster template creation</span
                  >
                  <span class="case-study__caption-dot"
                    >&nbsp;&middot;&nbsp;</span
                  >
                  <span class="case-study__caption-year"
                    >2025 &middot; Coming soon</span
                  >
                </p>
              </div>
            </div>
            <a href="/output-builder" class="case-study__link" aria-label="View Output Builder case study">
            <div
              class="case-study__image-wrap"
              style="background: rgba(209, 227, 255, 0.88)"
            >
              <div class="case-study__tilt">
                <div class="tilt-glare"></div>
                <Image
                  class="case-study__image"
                  src={outputBuilderImg}
                  alt="Output Builder visual template editor"
                  width={1200}
                  height={800}
                  loading="lazy"
                />
              </div>
            </div>
            </a>
          </div>

          <!-- Project 2 -->
          <div class="case-study">
            <div class="case-study__header">
              <div class="case-study__text">
                <h2 class="case-study__title shiny-hover">
                  Designing AI-native clinical documentation, before AI was a
                  thing
                </h2>
                <p class="case-study__caption">
                  <span class="case-study__caption-desc"
                    >AmbientOne &middot; 30+ modules shipped</span
                  >
                  <span class="case-study__caption-dot"
                    >&nbsp;&middot;&nbsp;</span
                  >
                  <span class="case-study__caption-year">2021</span>
                </p>
              </div>
            </div>
            <a href="/clinical-documentation" class="case-study__link" aria-label="View Clinical Documentation case study">
            <div
              class="case-study__image-wrap"
              style="background: rgba(225, 240, 255, 0.88)"
            >
              <div class="case-study__tilt">
                <div class="tilt-glare"></div>
                <Image
                  class="case-study__image"
                  src={clinicalDocImg}
                  alt="Clinical documentation platform"
                  width={1200}
                  height={800}
                  loading="lazy"
                />
              </div>
            </div>
            </a>
          </div>

          <!-- Project 3 -->
          <div class="case-study">
            <div class="case-study__header">
              <div class="case-study__text">
                <h2 class="case-study__title shiny-hover">
                  Getting an AI stylist app out of its own way
                </h2>
                <p class="case-study__caption">
                  <span class="case-study__caption-desc"
                    >Concept &middot; Faster first recommendation</span
                  >
                  <span class="case-study__caption-dot"
                    >&nbsp;&middot;&nbsp;</span
                  >
                  <span class="case-study__caption-year">2024</span>
                </p>
              </div>
            </div>
            <a href="/ai-stylist" class="case-study__link" aria-label="View AI Stylist Redesign case study">
            <div
              class="case-study__image-wrap"
              style="background: rgba(220, 240, 230, 0.88)"
            >
              <div class="case-study__tilt">
                <div class="tilt-glare"></div>
                <Image
                  class="case-study__image"
                  src={aiStylistImg}
                  alt="AI Stylist redesign"
                  width={1200}
                  height={800}
                  loading="lazy"
                />
              </div>
            </div>
            </a>
          </div>

          <!-- Project 4 -->
          <div class="case-study">
            <div class="case-study__header">
              <div class="case-study__text">
                <h2 class="case-study__title shiny-hover">
                  Turning a fragmented enrollment flow into one guided
                  experience
                </h2>
                <p class="case-study__caption">
                  <span class="case-study__caption-desc"
                    >Empyra &middot; Zero lost users</span
                  >
                  <span class="case-study__caption-dot"
                    >&nbsp;&middot;&nbsp;</span
                  >
                  <span class="case-study__caption-year"
                    >2025 &middot; 🔒 Password protected</span
                  >
                </p>
              </div>
            </div>
            <a href="/form-taking" class="case-study__link" aria-label="View Form Taking enrollment case study">
            <div
              class="case-study__image-wrap"
              style="background: rgba(255, 240, 220, 0.88)"
            >
              <div class="case-study__tilt">
                <div class="tilt-glare"></div>
                <Image
                  class="case-study__image"
                  src={formTakingImg}
                  alt="Form Taking enrollment flow"
                  width={1200}
                  height={800}
                  loading="lazy"
                />
              </div>
            </div>
            </a>
          </div>
        </div><!-- /.case-studies -->

        <!-- More Work -->
        <div class="more-work reveal-scroll">
          <div class="more-work__item">
            <Image
              src={aiTranscriptionImg}
              alt="Intelligent clinical transcription"
              width={96}
              height={64}
              loading="lazy"
            />
            <div>
              <p class="more-work__meta">
                Healthcare AI &middot; 2015&ndash;2018
              </p>
              <h4>Intelligent clinical transcription</h4>
            </div>
            <span class="more-work__soon">1000+ screens</span>
          </div>
          <div class="more-work__item">
            <Image
              src={snapIntakeImg}
              alt="Paper-to-digital patient intake"
              width={96}
              height={64}
              loading="lazy"
            />
            <div>
              <p class="more-work__meta">Healthcare AI &middot; 2020</p>
              <h4>Paper-to-digital patient intake</h4>
            </div>
            <span class="more-work__soon">Coming soon</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Experience Section -->
    <section id="experience" class="section experience-section">
      <div class="centered">
        <h2 class="experience__heading shiny-hover reveal-scroll">
          Experience
        </h2>
        <div class="experience__rows">
          <div class="experience__row reveal-scroll">
            <div class="experience__left">
              <div
                class="experience__logo"
                style="background:#e74c3c;border-radius:12px;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;"
              >
                E
              </div>
              <div class="experience__details">
                <div class="experience__title">Product Designer</div>
                <div class="experience__caption">
                  Empyra <span class="experience__caption-dot"
                    >&nbsp;&middot;&nbsp;</span
                  > Aug 2023 &minus; Jan 2026
                </div>
              </div>
            </div>
            <p class="experience__desc">
              Led redesign of complex admin workflows during a .NET-to-React
              migration. Managed two Figma design systems and maintained WCAG
              accessibility across the product.
            </p>
          </div>

          <div class="experience__row reveal-scroll">
            <div class="experience__left">
              <div
                class="experience__logo"
                style="background:#14a800;border-radius:12px;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;"
              >
                U
              </div>
              <div class="experience__details">
                <div class="experience__title">Freelance Product Designer</div>
                <div class="experience__caption">
                  Upwork &middot; Top Rated <span
                    class="experience__caption-dot">&nbsp;&middot;&nbsp;</span
                  > Apr 2023 &minus; Jul 2023
                </div>
              </div>
            </div>
            <p class="experience__desc">
              Delivered MVPs for AI and B2B startups globally while balancing
              production speed with product quality.
            </p>
          </div>

          <div class="experience__row reveal-scroll">
            <div class="experience__left">
              <div
                class="experience__logo"
                style="background:#2980b9;border-radius:12px;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;"
              >
                A
              </div>
              <div class="experience__details">
                <div class="experience__title">
                  Founding / Lead Product Designer
                </div>
                <div class="experience__caption">
                  AmbientOne (formerly Auxo Labs) <span
                    class="experience__caption-dot">&nbsp;&middot;&nbsp;</span
                  > Mar 2015 &minus; Jul 2023
                </div>
              </div>
            </div>
            <p class="experience__desc">
              Designed AI-powered healthcare products, led a seven-person design
              team, and built standards for shipping at scale.
            </p>
          </div>

          <div class="experience__row reveal-scroll">
            <div class="experience__left">
              <div
                class="experience__logo"
                style="background:#53469B;border-radius:12px;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;"
              >
                S
              </div>
              <div class="experience__details">
                <div class="experience__title">UI / Graphic Designer</div>
                <div class="experience__caption">
                  Spiceblue <span class="experience__caption-dot"
                    >&nbsp;&middot;&nbsp;</span
                  > 2014 &minus; 2015
                </div>
              </div>
            </div>
            <p class="experience__desc">
              Designed a leave management workflow for Kissflow, a low-code
              workflow platform, improving usability for day-to-day
              administrative tasks.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Block -->
    <section class="cta-block reveal-scroll">
      <div class="centered">
        <div class="cta-block__content">
          <span class="cta-block__label shiny-hover shiny-hover--blue"
            >Building something complex? Let's talk.</span
          >
          <a href="#" class="case-study__btn cta-block__btn" id="ctaCopyEmail">
            <span>Copy Email</span>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
              ><path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M5.75 11C5.33579 11 5 11.3358 5 11.75C5 12.1642 5.33579 12.5 5.75 12.5L16.6487 12.5L13.1738 16.2698C12.9087 16.5881 12.9517 17.061 13.2699 17.3261C13.5881 17.5913 14.061 17.5483 14.3262 17.2301L18.8262 12.2301C19.0579 11.952 19.0579 11.548 18.8262 11.2698L14.3262 6.26984C14.061 5.95163 13.5881 5.90864 13.2699 6.17382C12.9517 6.43899 12.9087 6.91191 13.1738 7.23012L16.6487 11L5.75 11Z"
                fill="#FFF1F2"></path></svg
            >
          </a>
        </div>
      </div>
    </section>

    <!-- Principles -->
    <section id="principles" class="section principles-section">
      <div class="centered">
        <h2 class="principles__heading shiny-hover reveal-scroll">
          How I work
        </h2>
        <div class="principles__grid">
          <div class="principle reveal-scroll">
            <span class="principle__index">01</span>
            <h3 class="principle__title">Fix the workflow first</h3>
            <p class="principle__copy">
              A pretty interface can't save a broken process. I map the whole
              user journey and remove friction before I draw a screen.
            </p>
          </div>
          <div class="principle reveal-scroll">
            <span class="principle__index">02</span>
            <h3 class="principle__title">Design with engineering</h3>
            <p class="principle__copy">
              I write HTML and CSS, so I spec what can actually be built. Nobody
              has to translate between design and code.
            </p>
          </div>
          <div class="principle reveal-scroll">
            <span class="principle__index">03</span>
            <h3 class="principle__title">Keep everything consistent</h3>
            <p class="principle__copy">
              One decision, applied everywhere. I follow a strict 4px grid and
              avoid one-off exceptions.
            </p>
          </div>
          <div class="principle reveal-scroll">
            <span class="principle__index">04</span>
            <h3 class="principle__title">Accessibility is the baseline</h3>
            <p class="principle__copy">
              Built in from the start, not audited at the end. Designing for
              edge cases makes the whole product better.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Skills -->
    <section id="skills" class="section skills-section">
      <div class="centered">
        <h2 class="skills__heading shiny-hover reveal-scroll">Capabilities</h2>
        <div class="skills__grid reveal-scroll">
          <div class="skill-card">
            <div class="skill-card__title">Systems &amp; craft</div>
            <p class="skill-card__copy">
              Design thinking and information architecture as the foundation.
              Scalable design systems built on MUI, shadcn, and UntitledUI.
              Static and interactive prototyping in Figma, motion in Jitter.
            </p>
          </div>
          <div class="skill-card">
            <div class="skill-card__title">AI-assisted delivery</div>
            <p class="skill-card__copy">
              Rapid prototyping and vibe coding with Claude Code, Antigravity,
              Codex, and Windsurf. HITL (human-in-the-loop) patterns for
              AI-integrated products.
            </p>
          </div>
          <div class="skill-card">
            <div class="skill-card__title">Leadership</div>
            <p class="skill-card__copy">
              Cross-functional collaboration beyond handoffs. Mentoring and
              design direction for teams up to 7+, in agile environments with
              high-fidelity client communication.
            </p>
          </div>
          <div class="skill-card">
            <div class="skill-card__title">Accessibility</div>
            <p class="skill-card__copy">
              WCAG 2.2 compliance from the start, not bolted on. Heuristic
              evaluation of UI components and clarity-first UX copy.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- About -->
    <section id="about" class="section about-section">
      <div class="centered">
        <h2 class="about__heading shiny-hover reveal-scroll">About me</h2>

        <div class="about__body">
          <div class="about__content">
            <p>
              I've spent most of my career as a sole designer, owning products
              from problem framing to delivery: clinical AI platforms,
              enrollment systems, styling apps.
            </p>
            <p>
              I take complex systems with confusing workflows and technical
              constraints and turn them into interfaces people can actually use.
              Most of what I've built is used daily by internal teams, where
              reliability matters as much as clarity.
            </p>
            <p>
              I use AI as a multiplier: Claude Code and Figma AI to ideate
              faster, prototype in real code, and ship the leanest thing that
              delivers the most value.
            </p>
          </div>

          <div class="about__hero-photo" id="aboutHeroPhoto">
            <div class="about__hero-glare"></div>
            <Image
              src={profileImg}
              alt="Viknesh Vijayakumar"
              width={220}
              height={220}
              loading="lazy"
            />
          </div>
        </div>

        <div class="about__footer reveal-scroll">
          <!-- CTA Card -->
          <div class="about__cta-card">
            <div class="about__cta-title shiny-hover shiny-hover--blue">
              Tell me what you're building.<br class="about__cta-br" /> Let's see
              if it's a fit.
            </div>
            <div class="about__cta-controls">
              <div class="about__email-pill">
                <span class="about__email-text">{EMAIL}</span>
                <button
                  class="about__icon-btn"
                  id="aboutCopyEmail"
                  aria-label="Copy email"
                >
                  <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><rect x="9" y="9" width="13" height="13" rx="2" ry="2"
                    ></rect><path
                      d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                    ></path></svg
                  >
                </button>
              </div>
              <a
                href={RESUME}
                target="_blank"
                rel="noopener"
                class="case-study__btn about__book-btn"
              >
                <span>Download resume</span>
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none"
                  ><path
                    fill-rule="evenodd"
                    clip-rule="evenodd"
                    d="M5.75 11C5.33579 11 5 11.3358 5 11.75C5 12.1642 5.33579 12.5 5.75 12.5L16.6487 12.5L13.1738 16.2698C12.9087 16.5881 12.9517 17.061 13.2699 17.3261C13.5881 17.5913 14.061 17.5483 14.3262 17.2301L18.8262 12.2301C19.0579 11.952 19.0579 11.548 18.8262 11.2698L14.3262 6.26984C14.061 5.95163 13.5881 5.90864 13.2699 6.17382C12.9517 6.43899 12.9087 6.91191 13.1738 7.23012L16.6487 11L5.75 11Z"
                    fill="#FFF1F2"></path></svg
                >
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="centered">
        <div class="footer__inner">
          <span class="footer__copyright"
            ><span id="footerYear"></span> &copy;&#65039; <strong
              >Viknesh Vijayakumar</strong
            >. All rights reserved.</span
          >
          <div class="footer__socials">
            <a
              href={DRIBBBLE}
              target="_blank"
              rel="noopener"
              class="footer__social"
              aria-label="Dribbble"
            >
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><circle cx="12" cy="12" r="10"></circle><path
                  d="M8.56 2.75c4.37 6.03 6.02 9.42 8.03 17.72m2.54-15.38c-3.72 4.35-8.94 5.66-16.88 5.85m19.5 1.9c-3.5-.93-6.63-.82-8.94 0-2.58.92-5.01 2.86-7.44 6.32"
                ></path></svg
              >
            </a>
            <a
              href={LINKEDIN}
              target="_blank"
              rel="noopener"
              class="footer__social"
              aria-label="LinkedIn"
            >
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
                ></path><rect x="2" y="9" width="4" height="12"></rect><circle
                  cx="4"
                  cy="4"
                  r="2"></circle></svg
              >
            </a>
            <a
              href={WHATSAPP}
              target="_blank"
              rel="noopener"
              class="footer__social"
              aria-label="WhatsApp"
            >
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"
