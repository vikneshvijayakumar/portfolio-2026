---

<Layout
  title="Viknesh Vijayakumar — Lead Product Designer"
  description="I make complex B2B software feel refreshingly simple. 12 years in product design, 8 in healthcare AI."
  ogImage="/assets/profile.webp"
  pageClass="home-page"
>
  <script is:inline>
    // Resolve the theme before first paint so dark mode never flashes white.
    (() => {
      const saved = localStorage.getItem("viknesh-theme");
      document.documentElement.dataset.theme =
        saved === "ink" || saved === "paper"
          ? saved
          : matchMedia("(prefers-color-scheme: dark)").matches
            ? "ink"
            : "paper";
    })();
  </script>

  <style is:global>
    @keyframes pulseDot {
      0%,
      100% {
        box-shadow: 0 0 0 0 rgba(22, 163, 74, 0.45);
      }
      50% {
        box-shadow: 0 0 0 6px rgba(22, 163, 74, 0);
      }
    }
    @keyframes floatCursor {
      0%,
      100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-5px);
      }
    }
    @keyframes tickerX {
      from {
        transform: translateX(0);
      }
      to {
        transform: translateX(-50%);
      }
    }
    /* ── Hero entrance ── */
    @keyframes fxUp {
      from {
        opacity: 0;
        transform: translateY(24px);
      }
      to {
        opacity: 1;
        transform: none;
      }
    }
    @keyframes wordUp {
      from {
        transform: translateY(115%);
      }
      to {
        transform: none;
      }
    }
    @keyframes cornerPop {
      from {
        transform: scale(0);
      }
      to {
        transform: scale(1);
      }
    }
    .fx {
      opacity: 0;
      animation: fxUp 0.9s var(--ease-out-quart) forwards;
      animation-delay: var(--d, 0s);
    }
    /* Masked word reveal (hero h1 + section headings) */
    .w-mask {
      display: inline-block;
      overflow: hidden;
      vertical-align: bottom;
      padding-bottom: 0.12em;
      margin-bottom: -0.12em;
    }
    .w-in {
      display: inline-block;
      transform: translateY(115%);
    }
    .hero-ready [data-rsp="hero-line"] .w-in {
      animation: wordUp 0.9s var(--ease-out-quart) forwards;
      animation-delay: calc(var(--i) * 70ms);
    }
    .hero-l2 {
      display: inline-block;
      opacity: 0;
      animation: fxUp 0.9s var(--ease-out-quart) 0.45s forwards;
    }
    .hero-l2 .corner {
      transform: scale(0);
      animation: cornerPop 0.45s var(--ease-out-back) forwards;
    }
    .hero-l2 .corner:nth-of-type(1) {
      animation-delay: 1s;
    }
    .hero-l2 .corner:nth-of-type(2) {
      animation-delay: 1.12s;
    }
    .hero-l2 .corner:nth-of-type(3) {
      animation-delay: 1.24s;
    }
    /* Heading word cascade on scroll */
    [data-reveal="words"] .w-in {
      transition: transform 0.85s var(--ease-out-quart);
      transition-delay: calc(var(--i) * 80ms);
    }
    [data-reveal="words"].in .w-in {
      transform: none;
    }
    /* ── Hero dot-grid spotlight ── */
    #top::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      background-image: radial-gradient(var(--ac) 1.5px, transparent 1.5px);
      background-size: 26px 26px;
      opacity: 0;
      transition: opacity 0.35s ease;
      -webkit-mask-image: radial-gradient(
        240px circle at var(--mx, 50%) var(--my, 50%),
        #000 0%,
        transparent 72%
      );
      mask-image: radial-gradient(
        240px circle at var(--mx, 50%) var(--my, 50%),
        #000 0%,
        transparent 72%
      );
    }
    #top:hover::after {
      opacity: 0.55;
    }
    /* ── Tickers ── */
    .ticker:hover .ticker-track {
      animation-play-state: paused;
    }
    .ticker-track--reverse {
      animation-direction: reverse;
    }
    /* The masthead logo ships as an <img>, so it inverts via filter rather
       than the currentColor trace the canvas uses on its inline SVG. */
    .toolbar__mark img {
      filter: var(--logo-filter);
    }
    /* ── Scroll progress bar — pinned to the viewport, above the panels ── */
    #progress {
      position: fixed;
      left: 0;
      top: 0;
      width: 100%;
      height: 2px;
      background: var(--ac);
      transform: scaleX(0);
      transform-origin: left;
      z-index: 101;
    }
    /* ── Theme toggle icons (scoped past header.css's `.theme-toggle-minimal svg`) ── */
    .theme-toggle-minimal .icon-sun {
      display: none;
    }
    :root[data-theme="ink"] .theme-toggle-minimal .icon-sun {
      display: block;
    }
    :root[data-theme="ink"] .theme-toggle-minimal .icon-moon {
      display: none;
    }
    /* ── Work cards: depth while stacking ── */
    [data-card-index] {
      transform-origin: top center;
      will-change: transform, filter;
    }
    /* ── Contact email underline sweep ── */
    .email-link {
      background-image: linear-gradient(var(--accent-300), var(--accent-300));
      background-repeat: no-repeat;
      background-size: 0% 0.045em;
      background-position: 0 96%;
      transition: background-size 0.6s var(--ease-in-out-quart);
    }
    .email-link:hover {
      background-size: 100% 0.045em;
    }
    .copied-indicator {
      display: inline-block;
      font-family: var(--font), sans-serif;
      font-size: clamp(12px, 1.5vw, 15px);
      font-weight: 600;
      color: #10b981;
      opacity: 0;
      transform: scale(0.9) translate3d(0, 4px, 0);
      transition:
        opacity 0.35s var(--ease-out-back),
        transform 0.35s var(--ease-out-back);
      white-space: nowrap;
      padding: 6px 12px;
      border-radius: 999px;
      background: rgba(16, 185, 129, 0.1);
      border: 1px solid rgba(16, 185, 129, 0.2);
      pointer-events: none;
    }
    .copied-indicator.is-visible {
      opacity: 1;
      transform: scale(1) translate3d(0, 0, 0);
    }
    .email-copy-icon {
      width: 0.38em;
      height: 0.38em;
      min-width: 24px;
      min-height: 24px;
      opacity: 0.45;
      transition: opacity 0.2s var(--ease-in-out-quart);
      margin-left: 0.12em;
      display: inline-block;
      flex-shrink: 0;
    }
    .email-link:hover .email-copy-icon {
      opacity: 0.85;
    }
    /* ── Badge Tooltips ── */
    .badge-link {
      position: relative;
    }
    .badge-link .custom-tooltip {
      position: absolute;
      bottom: 100%;
      left: 50%;
      transform: translateX(-50%) translateY(-4px);
      background: var(--surface-strong);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      color: var(--text);
      padding: 4px 12px;
      border-radius: 4px;
      font-family: var(--font), sans-serif;
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0;
      white-space: nowrap;
      pointer-events: none;
      opacity: 0;
      border: 1px solid var(--border);
      box-shadow: 0 4px 12px rgba(15, 21, 36, 0.08);
      transition:
        opacity 0.3s cubic-bezier(0.25, 1, 0.5, 1),
        transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
      z-index: 10;
    }
    .badge-link .custom-tooltip::before {
      content: "";
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      border-width: 5px;
      border-style: solid;
      border-color: var(--surface-strong) transparent transparent transparent;
    }
    .badge-link:hover .custom-tooltip,
    .badge-link:focus-visible .custom-tooltip {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
    @media (prefers-reduced-motion: reduce) {
      .fx,
      .hero-l2,
      .w-in,
      .hero-l2 .corner {
        animation: none !important;
        opacity: 1 !important;
        transform: none !important;
      }
      .ticker-track,
      [style*="floatCursor"],
      [style*="pulseDot"] {
        animation: none !important;
      }
      #top::after {
        display: none;
      }
    }
    /* ── Ask AI card — sits at the base of the hero, below the action row ── */
    .ask-ai-slot {
      margin-top: clamp(48px, 9vh, 110px);
    }
    [data-rsp="burger"] {
      display: none !important;
    }
    /* The right panel runs out of room before the nav does — shed the
       decorative pill and the resume CTA first (the mobile menu has both). */
    @media (max-width: 1100px) {
      [data-rsp="pill"],
      [data-rsp="resume"] {
        display: none !important;
      }
    }
    @media (max-width: 900px) {
      [data-rsp="nav"] {
        display: none !important;
      }
      [data-rsp="burger"] {
        display: flex !important;
      }
      [data-rsp="case"] {
        position: relative !important;
        top: auto !important;
        left: auto !important;
        right: auto !important;
        grid-template-columns: 1fr !important;
        height: auto !important;
        gap: 32px !important;
        padding: 32px 24px !important;
        opacity: 1 !important;
        transform: none !important;
        margin-bottom: 24px;
      }
      #work-pinned {
        position: relative !important;
        top: auto !important;
        padding-top: 0 !important;
      }
      #work {
        padding-top: 80px !important;
        padding-bottom: 80px !important;
      }
      [data-rsp="case"] img {
        max-height: none !important;
      }
      [data-rsp="xp"] {
        grid-template-columns: 1fr !important;
        gap: 12px !important;
        padding: 40px 0 !important;
      }
      [data-rsp="about"] {
        grid-template-columns: 1fr !important;
        gap: 56px !important;
      }
      [data-rsp="about"] > div:first-child {
        max-width: 340px;
        margin: 0 auto;
        width: 100%;
      }
      [data-rsp="hero-line"] {
        font-size: clamp(40px, 10.5vw, 104px) !important;
      }
      [data-rsp="hero-h1"] {
        font-size: clamp(40px, 10.5vw, 124px) !important;
      }
    }
  </style>

  <!-- Cursor halo, shared with the canvas landing (styles/glow.css) -->
  <div class="mouse-glow" aria-hidden="true"></div>

  <!-- ══ MASTHEAD — shared chrome with the canvas landing (styles/header.css) ══ -->
  <header class="toolbar">
    <div class="toolbar__panel toolbar__panel--left">
      <div class="toolbar__left">
        <a class="toolbar__branding" href="#top">
          <span class="toolbar__mark">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="46"
              height="28"
              fill="none"
              viewBox="0 0 46 28"
              aria-label="Viknesh Vijayakumar logo"
            >
              <path
                fill="currentColor"
                d="m23.475 4 4.463 3.016v.61L16.362 24.663l-.518.353h-8.73L5.077 28h-.615L0 24.984v-.61L13.84 4h.614l4.462 3.016v.61l-9.83 14.47v2.182L22.861 4h.614Zm18.063 0L46 7.016v.61L34.424 24.663l-.517.353h-8.73L23.138 28h-.614l-4.463-3.016v-.61L31.902 4h.614l4.462 3.016v.61l-9.83 14.47v2.182L40.923 4h.615Z"
              ></path>
            </svg>
          </span>
          <span class="toolbar__identity">
            <span class="toolbar__name">Viknesh Vijayakumar</span>
            <span class="toolbar__role">Lead Product Designer</span>
          </span>
        </a>
        <nav class="header-zone-nav" data-rsp="nav" aria-label="Primary">
          <a class="header-zone-nav__item" href="#work"
            ><span class="header-zone-nav__label">Works</span></a
          >
          <a class="header-zone-nav__item" href="#experience"
            ><span class="header-zone-nav__label">Experience</span></a
          >
          <a class="header-zone-nav__item" href="#gallery"
            ><span class="header-zone-nav__label">Other Works</span></a
          >
          <a class="header-zone-nav__item" href="#about"
            ><span class="header-zone-nav__label">About</span></a
          >
          <a class="header-zone-nav__item" href="#contact"
            ><span class="header-zone-nav__label">Contact</span></a
          >
        </nav>
      </div>
    </div>

    <div class="toolbar__panel toolbar__panel--right">
      <div class="toolbar__actions">
        <a
          class="alt-landing-link"
          href="/canvas-landing"
          title="Canvas Landing"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="3" width="18" height="18" rx="2"></rect>
            <path d="M9 3v18M3 9h18"></path>
          </svg>
          <span class="alt-landing-link__label">Canvas Mode</span>
        </a>
        <a class="availability-pill" href="#contact" data-rsp="pill">
          <span class="availability-pill__dot" aria-hidden="true"></span>Open
          for opportunities
        </a>
        <button
          class="theme-toggle-minimal"
          id="themeToggle"
          type="button"
          aria-label="Switch to dark mode"
          title="Switch to dark mode"
        >
          <svg
            class="icon-sun"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M12 3V4M12 20V21M4 12H3M6.31412 6.31412L5.5 5.5M17.6859 6.31412L18.5 5.5M6.31412 17.69L5.5 18.5001M17.6859 17.69L18.5 18.5001M21 12H20M16 12C16 14.2091 14.2091 16 12 16C9.79086 16 8 14.2091 8 12C8 9.79086 9.79086 8 12 8C14.2091 8 16 9.79086 16 12Z"
            ></path>
          </svg>
          <svg
            class="icon-moon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M13 6V3M18.5 12V7M14.5 4.5H11.5M21 9.5H16M15.5548 16.8151C16.7829 16.8151 17.9493 16.5506 19 16.0754C17.6867 18.9794 14.7642 21 11.3698 21C6.74731 21 3 17.2527 3 12.6302C3 9.23576 5.02061 6.31331 7.92462 5C7.44944 6.05072 7.18492 7.21708 7.18492 8.44523C7.18492 13.0678 10.9322 16.8151 15.5548 16.8151Z"
            ></path>
