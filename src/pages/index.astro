  <script>
    // Theme — same localStorage key as the canvas landing, so the choice
    // carries across both. Applied pre-paint by the inline script in <head>.
    const themeToggle = document.getElementById("themeToggle");
    const applyTheme = (theme: string) => {
      document.documentElement.dataset.theme = theme;
      const label =
        theme === "ink" ? "Switch to light mode" : "Switch to dark mode";
      themeToggle?.setAttribute("aria-label", label);
      themeToggle?.setAttribute("title", label);
    };
    applyTheme(
      document.documentElement.dataset.theme === "ink" ? "ink" : "paper",
    );
    themeToggle?.addEventListener("click", () => {
      const next =
        document.documentElement.dataset.theme === "ink" ? "paper" : "ink";
      localStorage.setItem("viknesh-theme", next);
      applyTheme(next);
    });

    const EMAIL = "hello@viknesh.me";
    const reducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const finePointer = window.matchMedia("(pointer: fine)").matches;

    // Split marked elements into masked word spans (hero h1 line + headings)
    document
      .querySelectorAll<HTMLElement>("[data-split-words]")
      .forEach((el) => {
        const words = (el.textContent || "").trim().split(/\s+/);
        el.textContent = "";
        words.forEach((w, i) => {
          const mask = document.createElement("span");
          mask.className = "w-mask";
          const inner = document.createElement("span");
          inner.className = "w-in";
          inner.style.setProperty("--i", String(i));
          inner.textContent = w;
          mask.appendChild(inner);
          el.appendChild(mask);
          if (i < words.length - 1)
            el.appendChild(document.createTextNode(" "));
        });
      });
    // Kick off the hero word cascade once split spans exist
    requestAnimationFrame(() => document.body.classList.add("hero-ready"));

    // Cursor halo — same rAF-throttled commit the canvas uses, so the mask
    // invalidates at most once per frame. CSS hides the glow on coarse
    // pointers, so skip the listener entirely there.
    if (finePointer && !reducedMotion) {
      let gx = 0;
      let gy = 0;
      let glowRaf: number | null = null;
      const commitGlow = () => {
        glowRaf = null;
        document.documentElement.style.setProperty("--mouse-x", `${gx}px`);
        document.documentElement.style.setProperty("--mouse-y", `${gy}px`);
      };
      window.addEventListener(
        "mousemove",
        (e) => {
          gx = e.clientX;
          gy = e.clientY;
          if (glowRaf === null) glowRaf = requestAnimationFrame(commitGlow);
        },
        { passive: true },
      );
    }

    // Hero dot-grid spotlight follows the cursor
    const hero = document.getElementById("top");
    if (hero && finePointer && !reducedMotion) {
      hero.addEventListener("pointermove", (e) => {
        const r = hero.getBoundingClientRect();
        hero.style.setProperty("--mx", e.clientX - r.left + "px");
        hero.style.setProperty("--my", e.clientY - r.top + "px");
      });
    }

    // Magnetic pull on primary buttons
    if (finePointer && !reducedMotion) {
      document.querySelectorAll<HTMLElement>(".btn-primary").forEach((btn) => {
        btn.addEventListener("pointermove", (e) => {
          const r = btn.getBoundingClientRect();
          const dx = e.clientX - (r.left + r.width / 2);
          const dy = e.clientY - (r.top + r.height / 2);
          btn.style.transform = `translate(${dx * 0.18}px, ${dy * 0.28}px)`;
        });
        btn.addEventListener("pointerleave", () => {
          btn.style.transform = "";
        });
      });
    }

    // Mobile menu
    const menu = document.getElementById("menu");
    const openMenu = () => {
      if (menu) menu.style.display = "flex";
    };
    const closeMenu = () => {
      if (menu) menu.style.display = "none";
    };
    document.getElementById("burger")?.addEventListener("click", openMenu);
    document.getElementById("menuClose")?.addEventListener("click", closeMenu);
    document
      .querySelectorAll("[data-menu-link]")
      .forEach((a) => a.addEventListener("click", closeMenu));

    // Copy email
    document.querySelectorAll("[data-copy-email]").forEach((btn) => {
      const isEmailText = btn.classList.contains("email-link");
      const original = btn.textContent;
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        navigator.clipboard?.writeText(EMAIL).catch(() => {});
        if (isEmailText) {
          const indicator = btn.nextElementSibling;
          if (indicator && indicator.classList.contains("copied-indicator")) {
            indicator.classList.add("is-visible");
            setTimeout(() => {
              indicator.classList.remove("is-visible");
            }, 1600);
          }
        } else {
          btn.textContent = "Copied ✓";
          setTimeout(() => {
            btn.textContent = original;
          }, 1600);
        }
      });
    });

    // Smooth-scroll for in-page anchor links (JS instead of CSS scroll-behavior,
    // so back-navigation scroll restoration stays instant).
    document.addEventListener("click", (e) => {
      const a = (e.target as Element).closest?.('a[href^="#"]');
      if (!a) return;
      const target = document.querySelector(a.getAttribute("href") || "");
      if (!target) return;
      e.preventDefault();
      target.scrollIntoView({ behavior: "smooth" });
      history.pushState(null, "", a.getAttribute("href"));
    });

    // Stagger experience-row children and gallery cards into the reveal system
    document.querySelectorAll('[data-rsp="xp"]').forEach((row) => {
      [...row.children].forEach((c, i) => {
        c.setAttribute("data-reveal", "up");
        c.setAttribute("data-reveal-delay", String(i * 130));
      });
    });
    const galleryWrap = document.getElementById("galleryGrid");
    if (galleryWrap) {
      [...galleryWrap.children].forEach((c, i) => {
        c.setAttribute("data-reveal", "up");
        c.setAttribute("data-reveal-delay", String((i % 3) * 100));
      });
    }

    // Scroll reveals ("words" cascades masked word spans; others fade/slide).
    // Elements with their own transform (rotated polaroids, quote cards) keep
    // it: the hidden state composes translateY in front, the reveal restores it.
    const els = [...document.querySelectorAll<HTMLElement>("[data-reveal]")];
    els.forEach((el) => {
      if (el.getAttribute("data-reveal") === "words") return;
      el.dataset.tf0 = el.style.transform || "";
      el.style.opacity = "0";
      if (el.getAttribute("data-reveal") !== "fade")
        el.style.transform = "translateY(28px) " + el.dataset.tf0;
      el.style.transition =
        "opacity .75s cubic-bezier(.2,.6,.2,1), transform .75s cubic-bezier(.2,.6,.2,1)";
      el.style.willChange = "opacity, transform";
    });
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          if (el.getAttribute("data-reveal") === "words") {
            el.classList.add("in");
          } else {
            el.style.transitionDelay =
              (el.getAttribute("data-reveal-delay") || "0") + "ms";
            el.style.opacity = "1";
            el.style.transform = el.dataset.tf0 || "";
            // Hand transitions back to stylesheet rules (gal-card hover)
            el.addEventListener(
              "transitionend",
              () => {
                el.style.transition = "";
                el.style.transitionDelay = "";
                el.style.willChange = "";
              },
              { once: true },
            );
          }
          io.unobserve(el);
        });
      },
      { threshold: 0.12, rootMargin: "0px 0px -6% 0px" },
    );
    els.forEach((el) => io.observe(el));

    // Equalize case-study card heights: a sticky card releases when its bottom
    // meets the container bottom, so unequal heights make taller cards scroll
    // away before the rest of the stack.
    const workCards = [
      ...document.querySelectorAll<HTMLElement>("[data-card-index]"),
    ];
    const workPinned = document.getElementById("work-pinned");
    const workCardsWrap = document.getElementById("work-cards");
    const equalizeCards = () => {
      workCards.forEach((c) => (c.style.minHeight = "0"));
      if (workPinned) workPinned.style.paddingBottom = "";
      if (workCardsWrap) workCardsWrap.style.marginTop = "";
      if (window.matchMedia("(max-width: 900px)").matches) return;
      const h = Math.max(...workCards.map((c) => c.offsetHeight));
      workCards.forEach((c) => (c.style.minHeight = h + "px"));
      // Extend the pinned heading block (invisibly) so its sticky release point
      // matches the card stack's — heading and stack then scroll away together.
      // The cards wrapper is pulled up by the same amount so layout is unchanged.
      const lastCard = workCards[workCards.length - 1];
      if (workPinned && workCardsWrap && lastCard) {
        const stickyTop = parseFloat(getComputedStyle(lastCard).top) || 0;
        // Grow the block by the missing height, on top of its authored padding
        // (setting paddingBottom replaces the shorthand value, so add them).
        const padB =
          parseFloat(getComputedStyle(workPinned).paddingBottom) || 0;
        const grow = Math.max(0, stickyTop + h - workPinned.offsetHeight);
        workPinned.style.paddingBottom = padB + grow + "px";
        workCardsWrap.style.marginTop = -grow + "px";
      }
    };
    equalizeCards();
    window.addEventListener("load", equalizeCards);
    window.addEventListener("resize", equalizeCards);

    // Scroll-driven effects: progress bar, hero exit parallax,
    // and depth scaling as work cards stack over each other.
    const progress = document.getElementById("progress");
    const heroInner = document.getElementById("heroInner");
    const cardTops = () =>
      workCards.map((c) => parseFloat(getComputedStyle(c).top) || 0);
    let scrollRaf = 0;
    const onScroll = () => {
      scrollRaf = 0;
      const doc = document.documentElement;
      if (progress) {
        const max = doc.scrollHeight - window.innerHeight;
        progress.style.transform = `scaleX(${max > 0 ? window.scrollY / max : 0})`;
      }
      if (reducedMotion) return;
      const vh = window.innerHeight;
      if (heroInner && window.scrollY < vh) {
        const y = window.scrollY;
        heroInner.style.transform = `translateY(${y * 0.18}px)`;
        heroInner.style.opacity = String(Math.max(0, 1 - y / (vh * 0.9)));
      }
      if (!window.matchMedia("(max-width: 900px)").matches) {
        const tops = cardTops();
        workCards.forEach((card, i) => {
          const next = workCards[i + 1];
          if (!next) return;
          // Progress of the incoming card, from the moment this card pins
          // (next card sits one card-height + gap below) until the next card
          // reaches its own sticky top. Continuous — no jump at the pin point.
          const start = tops[i] + card.offsetHeight + 48;
          const nr = next.getBoundingClientRect();
          const p = Math.min(
            1,
            Math.max(0, (start - nr.top) / (start - tops[i + 1])),
          );
          card.style.transform = p > 0 ? `scale(${1 - 0.05 * p})` : "";
          card.style.filter = p > 0 ? `brightness(${1 - 0.09 * p})` : "";
        });
      } else {
        workCards.forEach((card) => {
          card.style.transform = "";
          card.style.filter = "";
        });
      }
    };
    window.addEventListener(
      "scroll",
      () => {
        if (!scrollRaf) scrollRaf = requestAnimationFrame(onScroll);
      },
      { passive: true },
    );
    onScroll();

    // Gallery lightbox
    const lb = document.getElementById("lightbox");
    const lbImg = document.getElementById(
      "lightboxImg",
    ) as HTMLImageElement | null;
    const openLb = (src: string, alt: string) => {
      if (!lb || !lbImg) return;
      lbImg.src = src;
      lbImg.alt = alt;
      lb.style.display = "flex";
      requestAnimationFrame(() => {
        lb.style.opacity = "1";
      });
      document.body.style.overflow = "hidden";
    };
    const closeLb = () => {
      if (!lb) return;
      lb.style.opacity = "0";
      setTimeout(() => {
        lb.style.display = "none";
      }, 200);
      document.body.style.overflow = "";
    };
    document
      .querySelectorAll<HTMLElement>("[data-lightbox]")
      .forEach((card) => {
        card.addEventListener("click", () => {
          openLb(
            card.getAttribute("data-lightbox") || "",
            card.querySelector("img")?.alt || "",
          );
        });
      });
    lb?.addEventListener("click", (e) => {
      if (e.target !== lbImg) closeLb();
    });
    document
      .getElementById("lightboxClose")
      ?.addEventListener("click", closeLb);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && lb?.style.display === "flex") closeLb();
    });

    // Masonry: distribute gallery cards into columns left-to-right (round-robin),
    // keeping the authored order as the reading order.
    const gal = document.getElementById("galleryGrid");
    if (gal) {
      const items = [...gal.children] as HTMLElement[];
      const build = () => {
        const n = gal.clientWidth >= 940 ? 3 : gal.clientWidth >= 640 ? 2 : 1;
        if (gal.dataset.cols === String(n)) return;
        gal.dataset.cols = String(n);
        gal.style.cssText = "display:flex;gap:32px;align-items:flex-start";
        gal.innerHTML = "";
        const cols = Array.from({ length: n }, () => {
          const c = document.createElement("div");
          c.style.cssText = "flex:1;min-width:0";
          gal.appendChild(c);
          return c;
        });
        items.forEach((item, i) => cols[i % n].appendChild(item));
      };
      build();
      addEventListener("resize", build);
    }

    // Springy parallax on the about portrait — only runs while on screen
    const frame = document.querySelector<HTMLElement>(
      '[data-parallax="frame"]',
    );
    const pimg = document.querySelector<HTMLElement>('[data-parallax="img"]');
    if (frame && pimg) {
      let cur = 0,
        vel = 0,
        raf = 0;
      const tick = () => {
        const r = frame.getBoundingClientRect();
        const target = -(r.top + r.height / 2 - window.innerHeight / 2) * 0.07;
        const accel = (target - cur) * 0.06;
        vel = (vel + accel) * 0.86;
        cur += vel;
        const rot = Math.max(-4.5, Math.min(-0.5, -2.5 + vel * 0.6));
        frame.style.transform =
          "translateY(" +
          cur.toFixed(2) +
          "px) rotate(" +
          rot.toFixed(2) +
          "deg)";
        pimg.style.transform =
          "translateY(" + (-cur * 0.35).toFixed(2) + "px) scale(1.08)";
        raf = requestAnimationFrame(tick);
      };
      new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting && !raf) raf = requestAnimationFrame(tick);
          else if (!e.isIntersecting && raf) {
            cancelAnimationFrame(raf);
            raf = 0;
          }
        });
      }).observe(frame);
    }
  </script>

  <style is:global>
    .btn-primary:hover {
      background: var(--btn-hover) !important;
      color: var(--btn-text) !important;
      transform: translateY(-1px);
    }
  </style>
</Layout>
