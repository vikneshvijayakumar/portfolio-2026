        xmlns="http://www.w3.org/2000/svg"
        width="46"
        height="28"
        fill="none"
        viewBox="0 0 46 28"
        aria-label="Viknesh Vijayakumar logo"
        style="display:block;height:26px;width:auto;color:var(--text)"
