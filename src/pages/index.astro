  <script>
    // Theme — same localStorage key as the canvas landing, so the choice
    // carries across both. Applied pre-paint by the inline script in <head>.
    const themeToggle = document.getElementById("themeToggle");
    const applyTheme = (theme: string) => {
      document.documentElement.dataset.theme = theme;
      const label =
        theme === "ink" ? "Switch to light mode" : "Switch to dark mode";
      themeToggle?.setAttribute("aria-label", label);
      themeToggle?.setAttribute("title", label);
    };
    applyTheme(
      document.documentElement.dataset.theme === "ink" ? "ink" : "paper",
    );
    themeToggle?.addEventListener("click", () => {
      const next =
        document.documentElement.dataset.theme === "ink" ? "paper" : "ink";
      localStorage.setItem("viknesh-theme", next);
      applyTheme(next);
    });

    const EMAIL = "hello@viknesh.me";
    const reducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const finePointer = window.matchMedia("(pointer: fine)").matches;

    // Split marked elements into masked word spans (hero h1 line + headings)
    document
      .querySelectorAll<HTMLElement>("[data-split-words]")
      .forEach((el) => {
        const words = (el.textContent || "").trim().split(/\s+/);
        el.textContent = "";
        words.forEach((w, i) => {
          const mask = document.createElement("span");
          mask.className = "w-mask";
          const inner = document.createElement("span");
          inner.className = "w-in";
          inner.style.setProperty("--i", String(i));
          inner.textContent = w;
          mask.appendChild(inner);
          el.appendChild(mask);
          if (i < words.length - 1)
            el.appendChild(document.createTextNode(" "));
        });
      });
    // Kick off the hero word cascade once split spans exist
    requestAnimationFrame(() => document.body.classList.add("hero-ready"));

    // Cursor halo — same rAF-throttled commit the canvas uses, so the mask
    // invalidates at most once per frame. CSS hides the glow on coarse
    // pointers, so skip the listener entirely there.
    if (finePointer && !reducedMotion) {
      let gx = 0;
      let gy = 0;
      let glowRaf: number | null = null;
      const commitGlow = () => {
        glowRaf = null;
        document.documentElement.style.setProperty("--mouse-x", `${gx}px`);
        document.documentElement.style.setProperty("--mouse-y", `${gy}px`);
      };
      window.addEventListener(
        "mousemove",
        (e) => {
          gx = e.clientX;
          gy = e.clientY;
          if (glowRaf === null) glowRaf = requestAnimationFrame(commitGlow);
        },
        { passive: true },
      );
    }

    // Hero dot-grid spotlight follows the cursor
    const hero = document.getElementById("top");
    if (hero && finePointer && !reducedMotion) {
      hero.addEventListener("pointermove", (e) => {
        const r = hero.getBoundingClientRect();
        hero.style.setProperty("--mx", e.clientX - r.left + "px");
        hero.style.setProperty("--my", e.clientY - r.top + "px");
      });
    }

    // Magnetic pull on primary buttons
    if (finePointer && !reducedMotion) {
      document.querySelectorAll<HTMLElement>(".btn-primary").forEach((btn) => {
        btn.addEventListener("pointermove", (e) => {
          const r = btn.getBoundingClientRect();
          const dx = e.clientX - (r.left + r.width / 2);
          const dy = e.clientY - (r.top + r.height / 2);
          btn.style.transform = `translate(${dx * 0.18}px, ${dy * 0.28}px)`;
        });
        btn.addEventListener("pointerleave", () => {
          btn.style.transform = "";
        });
      });
    }

    // Copy email
    document.querySelectorAll("[data-copy-email]").forEach((btn) => {
      const isEmailText = btn.classList.contains("email-link");
      const original = btn.textContent;
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        navigator.clipboard?.writeText(EMAIL).catch(() => {});
        if (isEmailText) {
          const indicator = btn.nextElementSibling;
          if (indicator && indicator.classList.contains("copied-indicator")) {
            indicator.classList.add("is-visible");
            setTimeout(() => {
              indicator.classList.remove("is-visible");
            }, 1600);
          }
        } else {
          btn.textContent = "Copied ✓";
          setTimeout(() => {
            btn.textContent = original;
          }, 1600);
        }
      });
    });

    // Scrollspy — a band across the upper-middle of the viewport decides the
    // "current" section, same feel as canvas mode. Drives both the desktop
    // header nav and the mobile dock (only one is visible per breakpoint).
    const mobileLinks = [
      ...document.querySelectorAll<HTMLAnchorElement>(
        ".mobile-dock__link:not(.mobile-dock__link--clone)",
      ),
    ];
    const allMobileLinks = [
      ...document.querySelectorAll<HTMLAnchorElement>(".mobile-dock__link"),
    ];
    const spyLinks = [
      ...document.querySelectorAll<HTMLAnchorElement>(
        '.header-zone-nav[data-rsp="nav"] a',
      ),
      ...allMobileLinks,
    ];
    const spyTargets = [
      ...new Set(spyLinks.map((a) => a.getAttribute("href") || "")),
    ]
      .map((h) => document.querySelector(h))
      .filter((el): el is HTMLElement => !!el)
      .sort((a, b) => a.offsetTop - b.offsetTop);
    let spyCurrent = "";
    let isLoopingTransition = false;

    const track = document.querySelector<HTMLElement>(".mobile-dock__track");

    const setActive = (id: string) => {
      if (spyCurrent === id) return;
      spyCurrent = id;

      spyLinks.forEach((a) => {
        const on = a.getAttribute("href") === `#${id}`;
        a.classList.toggle("is-active", on);
        if (a.classList.contains("mobile-dock__link")) {
          a.classList.toggle("is-ghost", !on);
        }
      });

      // Update mobile dock track translation to center active item
      if (track && mobileLinks.length > 0 && !isLoopingTransition) {
        const activeIdx = mobileLinks.findIndex(
          (a) => a.getAttribute("href") === `#${id}`,
        );
        if (activeIdx !== -1) {
          track.style.transform = `translateX(${(2.5 - activeIdx) * 110}px)`;
        }
      }
    };

    // Looping bottom bar navigation functions
    const navigateToIndex = (idx: number) => {
      let targetIdx = idx;

      if (idx < 0) {
        targetIdx = mobileLinks.length - 1; // loop around to Contact
      } else if (idx >= mobileLinks.length) {
        targetIdx = 0; // loop around to Home
      }

      const targetLink = mobileLinks[targetIdx];
      if (!targetLink) return;
      const targetId = targetLink.getAttribute("href");
      if (!targetId) return;

      const sectionId = targetId.substring(1);

      // Check if we are jumping across the boundary (looping)
      const currentIdx = mobileLinks.findIndex((a) =>
        a.classList.contains("is-active"),
      );
      const isLoopJump =
        (currentIdx === 0 && targetIdx === mobileLinks.length - 1) ||
        (currentIdx === mobileLinks.length - 1 && targetIdx === 0);

      if (isLoopJump && track) {
        isLoopingTransition = true;
        // Temporarily animate to the cloned item first
        const clonedIdx = targetIdx === 0 ? mobileLinks.length : -1;
        track.style.transform = `translateX(${(2.5 - clonedIdx) * 110}px)`;

        // After the animation finishes, snap instantly to the real position
        setTimeout(() => {
          if (track) {
            track.style.transition = "none";
            track.style.transform = `translateX(${(2.5 - targetIdx) * 110}px)`;
            track.offsetHeight; // Force reflow
            track.style.transition = "";
          }
          isLoopingTransition = false;
        }, 350); // Matches transition duration 350ms
      } else {
        // Normal non-loop translation
        if (track) {
          track.style.transform = `translateX(${(2.5 - targetIdx) * 110}px)`;
        }
      }

      setActive(sectionId);

      const targetEl = document.querySelector(targetId);
      if (targetEl) {
        targetEl.scrollIntoView({ behavior: "smooth" });
        history.pushState(null, "", targetId);
      }
    };

    const handlePrev = () => {
      if (isLoopingTransition) return;
      const currentIdx = mobileLinks.findIndex((a) =>
        a.classList.contains("is-active"),
      );
      const prevIdx = currentIdx === -1 ? 0 : currentIdx - 1;
      navigateToIndex(prevIdx);
    };

    const handleNext = () => {
      if (isLoopingTransition) return;
      const currentIdx = mobileLinks.findIndex((a) =>
        a.classList.contains("is-active"),
      );
      const nextIdx = currentIdx === -1 ? 0 : currentIdx + 1;
      navigateToIndex(nextIdx);
    };

    document
      .querySelector(".mobile-dock__arrow.prev")
      ?.addEventListener("click", (e) => {
        e.stopPropagation();
        handlePrev();
      });
    document
      .querySelector(".mobile-dock__arrow.next")
      ?.addEventListener("click", (e) => {
        e.stopPropagation();
        handleNext();
      });

    // Swipe/drag detection on mobile dock via pointer events (mouse & touch unified)
    let pointerStartX = 0;
    let pointerStartY = 0;
    let isPointerDown = false;
    let hasMoved = false;
    let preventClick = false;
    const mobileDock = document.querySelector(".mobile-dock");
    if (mobileDock) {
      mobileDock.addEventListener("pointerdown", (e: any) => {
        if (e.button !== 0 && e.pointerType === "mouse") return;
        isPointerDown = true;
        hasMoved = false;
        pointerStartX = e.clientX;
        pointerStartY = e.clientY;
        try {
          mobileDock.setPointerCapture(e.pointerId);
        } catch (err) {}
      });

      mobileDock.addEventListener("pointermove", (e: any) => {
        if (!isPointerDown) return;
        const diffX = e.clientX - pointerStartX;
        const diffY = e.clientY - pointerStartY;
        // If moved more than 10px, consider it a drag/swipe gesture, not a click
        if (Math.abs(diffX) > 10 || Math.abs(diffY) > 10) {
          hasMoved = true;
        }
      });

      mobileDock.addEventListener("pointerup", (e: any) => {
        if (!isPointerDown) return;
        isPointerDown = false;
        try {
          mobileDock.releasePointerCapture(e.pointerId);
        } catch (err) {}

        if (hasMoved) {
          const diffX = e.clientX - pointerStartX;
          const diffY = e.clientY - pointerStartY;
          // Make sure it's mostly a horizontal swipe gesture
          if (Math.abs(diffX) > Math.abs(diffY)) {
            if (Math.abs(diffX) > 30) {
              preventClick = true;
              if (diffX > 30) {
                handlePrev();
              } else if (diffX < -30) {
                handleNext();
              }
              // Reset preventClick in a timeout to allow subsequent actual clicks
              setTimeout(() => {
                preventClick = false;
              }, 50);
            }
          }
        }
      });

      mobileDock.addEventListener("pointercancel", (e: any) => {
        isPointerDown = false;
        hasMoved = false;
        try {
          mobileDock.releasePointerCapture(e.pointerId);
        } catch (err) {}
      });

      // Prevent native browser link dragging from interrupting the swipe
      mobileDock.addEventListener("dragstart", (e) => {
        e.preventDefault();
      });

      // Intercept clicks on the mobile dock and block them if they were part of a swipe
      mobileDock.addEventListener(
        "click",
        (e) => {
          if (preventClick) {
            e.preventDefault();
            e.stopPropagation();
          }
        },
        { capture: true },
      ); // Capture phase to block before global click handler receives it
    }

    // The last section's top may never reach the detection band before the
    // page bottoms out, so pin it explicitly once we're scrolled to the end.
    const atBottom = () =>
      window.innerHeight + window.scrollY >=
      document.documentElement.scrollHeight - 2;
    const lastId = () => spyTargets[spyTargets.length - 1]?.id || "";

    let lastIntersecting = spyTargets[0]?.id || "";

    const spy = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            lastIntersecting = entry.target.id;
          }
        });

        if (atBottom()) {
          setActive(lastId());
        } else if (lastIntersecting) {
          setActive(lastIntersecting);
        }
      },
      { rootMargin: "-30% 0px -60% 0px" },
    );
    spyTargets.forEach((t) => spy.observe(t));
    window.addEventListener(
      "scroll",
      () => {
        if (atBottom()) {
          setActive(lastId());
        } else if (lastIntersecting && spyCurrent !== lastIntersecting) {
          setActive(lastIntersecting);
        }
      },
      { passive: true },
    );

    // Initialize default active section on load
    setActive("top");

    // Smooth-scroll for in-page anchor links (JS instead of CSS scroll-behavior,
    // so back-navigation scroll restoration stays instant).
    document.addEventListener("click", (e) => {
      const a = (e.target as Element).closest?.('a[href^="#"]');
      if (!a) return;
      const href = a.getAttribute("href") || "";
      const target = document.querySelector(href);
      if (!target) return;
      e.preventDefault();

      // If it's a mobile dock link, update state instantly to make it loop & transition snappy
      if (a.classList.contains("mobile-dock__link")) {
        const linkHref = a.getAttribute("href") || "";
        const idx = mobileLinks.findIndex(
          (link) => link.getAttribute("href") === linkHref,
        );
        if (idx !== -1) {
          navigateToIndex(idx);
          return;
        }
      }

      target.scrollIntoView({ behavior: "smooth" });
      history.pushState(null, "", href);
    });

    // Stagger experience-row children and gallery cards into the reveal system
    document.querySelectorAll('[data-rsp="xp"]').forEach((row) => {
      [...row.children].forEach((c, i) => {
        c.setAttribute("data-reveal", "up");
        c.setAttribute("data-reveal-delay", String(i * 130));
      });
    });
    const galleryWrap = document.getElementById("galleryGrid");
    if (galleryWrap) {
      [...galleryWrap.children].forEach((c, i) => {
        c.setAttribute("data-reveal", "up");
        c.setAttribute("data-reveal-delay", String((i % 3) * 100));
      });
    }

    // Scroll reveals ("words" cascades masked word spans; others fade/slide).
    // Elements with their own transform (rotated polaroids, quote cards) keep
    // it: the hidden state composes translateY in front, the reveal restores it.
    const els = [...document.querySelectorAll<HTMLElement>("[data-reveal]")];
    els.forEach((el) => {
      if (el.getAttribute("data-reveal") === "words") return;
      el.dataset.tf0 = el.style.transform || "";
      el.style.opacity = "0";
      if (el.getAttribute("data-reveal") !== "fade")
        el.style.transform = "translateY(28px) " + el.dataset.tf0;
      el.style.transition =
        "opacity .75s cubic-bezier(.2,.6,.2,1), transform .75s cubic-bezier(.2,.6,.2,1)";
      el.style.willChange = "opacity, transform";
    });
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          if (el.getAttribute("data-reveal") === "words") {
            el.classList.add("in");
          } else {
            el.style.transitionDelay =
              (el.getAttribute("data-reveal-delay") || "0") + "ms";
            el.style.opacity = "1";
            el.style.transform = el.dataset.tf0 || "";
            // Hand transitions back to stylesheet rules (gal-card hover)
            el.addEventListener(
              "transitionend",
              () => {
                el.style.transition = "";
                el.style.transitionDelay = "";
                el.style.willChange = "";
              },
              { once: true },
            );
          }
          io.unobserve(el);
        });
      },
      { threshold: 0.12, rootMargin: "0px 0px -6% 0px" },
    );
    els.forEach((el) => io.observe(el));

    // Equalize case-study card heights: a sticky card releases when its bottom
    // meets the container bottom, so unequal heights make taller cards scroll
    // away before the rest of the stack.
    const workCards = [
      ...document.querySelectorAll<HTMLElement>("[data-card-index]"),
    ];
    const workPinned = document.getElementById("work-pinned");
    const workCardsWrap = document.getElementById("work-cards");
    const equalizeCards = () => {
      workCards.forEach((c) => (c.style.minHeight = "0"));
      if (workPinned) workPinned.style.paddingBottom = "";
      if (workCardsWrap) workCardsWrap.style.marginTop = "";
      if (window.matchMedia("(max-width: 900px)").matches) return;
      const h = Math.max(...workCards.map((c) => c.offsetHeight));
      workCards.forEach((c) => (c.style.minHeight = h + "px"));
      // Extend the pinned heading block (invisibly) so its sticky release point
      // matches the card stack's — heading and stack then scroll away together.
      // The cards wrapper is pulled up by the same amount so layout is unchanged.
      const lastCard = workCards[workCards.length - 1];
      if (workPinned && workCardsWrap && lastCard) {
        const stickyTop = parseFloat(getComputedStyle(lastCard).top) || 0;
        // Grow the block by the missing height, on top of its authored padding
        // (setting paddingBottom replaces the shorthand value, so add them).
        const padB =
          parseFloat(getComputedStyle(workPinned).paddingBottom) || 0;
        const grow = Math.max(0, stickyTop + h - workPinned.offsetHeight);
        workPinned.style.paddingBottom = padB + grow + "px";
        workCardsWrap.style.marginTop = -grow + "px";
      }
    };
    equalizeCards();
    window.addEventListener("load", equalizeCards);
    window.addEventListener("resize", equalizeCards);

    // Scroll-driven effects: progress bar, hero exit parallax,
    // and depth scaling as work cards stack over each other.
    const progress = document.getElementById("progress");
    const heroInner = document.getElementById("heroInner");
    const mobileMQ = window.matchMedia("(max-width: 900px)");
    // Sticky tops and card heights only change on resize. Reading them per
    // frame costs a style/layout recalc per card, on every card, forever.
    let cardTops: number[] = [];
    let cardHeights: number[] = [];
    const measureCards = () => {
      cardTops = workCards.map((c) => parseFloat(getComputedStyle(c).top) || 0);
      cardHeights = workCards.map((c) => c.offsetHeight);
    };
    // Registered after equalizeCards' own listeners, so it always measures the
    // equalized heights rather than the pre-equalized ones.
    measureCards();
    window.addEventListener("load", measureCards);
    window.addEventListener("resize", measureCards);
    let scrollRaf = 0;
    const onScroll = () => {
      scrollRaf = 0;
      // Every read happens up front, every write after. Interleaving them
      // forces a synchronous layout on each read.
      const y = window.scrollY;
      const vh = window.innerHeight;
      const max = document.documentElement.scrollHeight - vh;
      const stacking = !reducedMotion && !mobileMQ.matches;
      const rectTops = stacking
        ? workCards.map((c) => c.getBoundingClientRect().top)
        : [];

      if (progress) {
        progress.style.transform = `scaleX(${max > 0 ? y / max : 0})`;
      }
      if (reducedMotion) return;
      // Mobile hero is taller than the viewport, so a viewport-length fade
      // hides the Ask AI card at its base before it can be reached. Let it
      // scroll away on its own instead.
      if (heroInner && !mobileMQ.matches && y < vh) {
        heroInner.style.transform = `translateY(${y * 0.18}px)`;
        heroInner.style.opacity = String(Math.max(0, 1 - y / (vh * 0.9)));
      }
      if (stacking) {
        workCards.forEach((card, i) => {
          if (i === workCards.length - 1) return;
          // Progress of the incoming card, from the moment this card pins
          // (next card sits one card-height + gap below) until the next card
          // reaches its own sticky top. Continuous — no jump at the pin point.
          const start = cardTops[i] + cardHeights[i] + 48;
          const p = Math.min(
            1,
            Math.max(0, (start - rectTops[i + 1]) / (start - cardTops[i + 1])),
          );
          card.style.transform = p > 0 ? `scale(${1 - 0.05 * p})` : "";
          card.style.filter = p > 0 ? `brightness(${1 - 0.09 * p})` : "";
        });
      } else {
        workCards.forEach((card) => {
          card.style.transform = "";
          card.style.filter = "";
        });
      }
    };
    window.addEventListener(
      "scroll",
      () => {
        if (!scrollRaf) scrollRaf = requestAnimationFrame(onScroll);
      },
      { passive: true },
    );
    onScroll();
    // Crossing into mobile mid-fade would otherwise strand the hero
    // half-transparent, since nothing writes those styles below 900px.
    mobileMQ.addEventListener("change", () => {
      if (heroInner && mobileMQ.matches) {
        heroInner.style.transform = "";
        heroInner.style.opacity = "";
      }
    });

    // Gallery lightbox
    const lb = document.getElementById("lightbox");
    const lbImg = document.getElementById(
      "lightboxImg",
    ) as HTMLImageElement | null;
    const openLb = (src: string, alt: string) => {
      if (!lb || !lbImg) return;
      lbImg.src = src;
      lbImg.alt = alt;
      lb.style.display = "flex";
      requestAnimationFrame(() => {
        lb.style.opacity = "1";
      });
      document.body.style.overflow = "hidden";
    };
    const closeLb = () => {
      if (!lb) return;
      lb.style.opacity = "0";
      setTimeout(() => {
        lb.style.display = "none";
      }, 200);
      document.body.style.overflow = "";
    };
    document
      .querySelectorAll<HTMLElement>("[data-lightbox]")
      .forEach((card) => {
        card.addEventListener("click", () => {
          openLb(
            card.getAttribute("data-lightbox") || "",
            card.querySelector("img")?.alt || "",
          );
        });
      });
    lb?.addEventListener("click", (e) => {
      if (e.target !== lbImg) closeLb();
    });
    document
      .getElementById("lightboxClose")
      ?.addEventListener("click", closeLb);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && lb?.style.display === "flex") closeLb();
    });

    // Masonry: distribute gallery cards into columns left-to-right (round-robin),
    // keeping the authored order as the reading order.
    const gal = document.getElementById("galleryGrid");
    if (gal) {
      const items = [...gal.children] as HTMLElement[];
      const build = () => {
        const n = gal.clientWidth >= 940 ? 3 : gal.clientWidth >= 640 ? 2 : 1;
        if (gal.dataset.cols === String(n)) return;
        gal.dataset.cols = String(n);
        gal.style.cssText = "display:flex;gap:32px;align-items:flex-start";
        gal.innerHTML = "";
        const cols = Array.from({ length: n }, () => {
          const c = document.createElement("div");
          c.style.cssText = "flex:1;min-width:0";
          gal.appendChild(c);
          return c;
        });
        items.forEach((item, i) => cols[i % n].appendChild(item));
      };
      build();
      addEventListener("resize", build);
    }

    // Springy parallax on the about portrait — only runs while on screen
    const frame = document.querySelector<HTMLElement>(
      '[data-parallax="frame"]',
    );
    const pimg = document.querySelector<HTMLElement>('[data-parallax="img"]');
    if (frame && pimg) {
      let cur = 0,
        vel = 0,
        raf = 0;
      const tick = () => {
        const r = frame.getBoundingClientRect();
        const target = -(r.top + r.height / 2 - window.innerHeight / 2) * 0.07;
        const accel = (target - cur) * 0.06;
        vel = (vel + accel) * 0.86;
        cur += vel;
        const rot = Math.max(-4.5, Math.min(-0.5, -2.5 + vel * 0.6));
        frame.style.transform =
          "translateY(" +
          cur.toFixed(2) +
          "px) rotate(" +
          rot.toFixed(2) +
          "deg)";
        pimg.style.transform =
          "translateY(" + (-cur * 0.35).toFixed(2) + "px) scale(1.08)";
        raf = requestAnimationFrame(tick);
      };
      new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting && !raf) raf = requestAnimationFrame(tick);
          else if (!e.isIntersecting && raf) {
            cancelAnimationFrame(raf);
            raf = 0;
          }
        });
      }).observe(frame);
    }
  </script>

  <style is:global>
    .btn-primary:hover {
      background: var(--btn-hover) !important;
      color: var(--btn-text) !important;
      transform: translateY(-1px);
    }
  </style>
</Layout>
