---

<Layout
  title="Viknesh Vijayakumar — Lead Product Designer"
  description="I make complex B2B software feel refreshingly simple. 12 years in product design, 8 in healthcare AI."
  ogImage="/assets/profile.webp"
  pageClass="home-page"
>
  <style is:global>
    @keyframes pulseDot {
      0%,
      100% {
        box-shadow: 0 0 0 0 rgba(22, 163, 74, 0.45);
      }
      50% {
        box-shadow: 0 0 0 6px rgba(22, 163, 74, 0);
      }
    }
    @keyframes floatCursor {
      0%,
      100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-5px);
      }
    }
    @keyframes tickerX {
      from {
        transform: translateX(0);
      }
      to {
        transform: translateX(-50%);
      }
    }
    /* ── Hero entrance ── */
    @keyframes fxUp {
      from {
        opacity: 0;
        transform: translateY(24px);
      }
      to {
        opacity: 1;
        transform: none;
      }
    }
    @keyframes wordUp {
      from {
        transform: translateY(115%);
      }
      to {
        transform: none;
      }
    }
    @keyframes cornerPop {
      from {
        transform: scale(0);
      }
      to {
        transform: scale(1);
      }
    }
    .fx {
      opacity: 0;
      animation: fxUp 0.9s var(--ease-out-quart) forwards;
      animation-delay: var(--d, 0s);
    }
    /* Masked word reveal (hero h1 + section headings) */
    .w-mask {
      display: inline-block;
      overflow: hidden;
      vertical-align: bottom;
      padding-bottom: 0.12em;
      margin-bottom: -0.12em;
    }
    .w-in {
      display: inline-block;
      transform: translateY(115%);
    }
    .hero-ready [data-rsp="hero-line"] .w-in {
      animation: wordUp 0.9s var(--ease-out-quart) forwards;
      animation-delay: calc(var(--i) * 70ms);
    }
    .hero-l2 {
      display: inline-block;
      opacity: 0;
      animation: fxUp 0.9s var(--ease-out-quart) 0.45s forwards;
    }
    .hero-l2 .corner {
      transform: scale(0);
      animation: cornerPop 0.45s var(--ease-out-back) forwards;
    }
    .hero-l2 .corner:nth-of-type(1) {
      animation-delay: 1s;
    }
    .hero-l2 .corner:nth-of-type(2) {
      animation-delay: 1.12s;
    }
    .hero-l2 .corner:nth-of-type(3) {
      animation-delay: 1.24s;
    }
    /* Heading word cascade on scroll */
    [data-reveal="words"] .w-in {
      transition: transform 0.85s var(--ease-out-quart);
      transition-delay: calc(var(--i) * 80ms);
    }
    [data-reveal="words"].in .w-in {
      transform: none;
    }
    /* ── Hero dot-grid spotlight ── */
    #top::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      background-image: radial-gradient(var(--ac) 1.5px, transparent 1.5px);
      background-size: 26px 26px;
      opacity: 0;
      transition: opacity 0.35s ease;
      -webkit-mask-image: radial-gradient(
        240px circle at var(--mx, 50%) var(--my, 50%),
        #000 0%,
        transparent 72%
      );
      mask-image: radial-gradient(
        240px circle at var(--mx, 50%) var(--my, 50%),
        #000 0%,
        transparent 72%
      );
    }
    #top:hover::after {
      opacity: 0.55;
    }
    /* ── Tickers ── */
    .ticker:hover .ticker-track {
      animation-play-state: paused;
    }
    .ticker-track--reverse {
      animation-direction: reverse;
    }
    /* The masthead logo ships as an <img>, so it inverts via filter rather
       than the currentColor trace the canvas uses on its inline SVG. */
    .toolbar__mark img {
      filter: var(--logo-filter);
    }
    /* ── Scroll progress bar — pinned to the viewport, above the panels ── */
    #progress {
      position: fixed;
      left: 0;
      top: 0;
      width: 100%;
      height: 2px;
      background: var(--ac);
      transform: scaleX(0);
      transform-origin: left;
      z-index: 101;
    }
    /* ── Theme toggle icons (scoped past header.css's `.theme-toggle-minimal svg`) ── */
    .theme-toggle-minimal .icon-sun {
      display: none;
    }
    :root[data-theme="ink"] .theme-toggle-minimal .icon-sun {
      display: block;
    }
    :root[data-theme="ink"] .theme-toggle-minimal .icon-moon {
      display: none;
    }
    /* ── Work cards: depth while stacking ── */
    [data-card-index] {
      transform-origin: top center;
      will-change: transform, filter;
    }
    /* ── Contact email underline sweep ── */
    .email-link {
      background-image: linear-gradient(var(--accent-300), var(--accent-300));
      background-repeat: no-repeat;
      background-size: 0% 0.045em;
      background-position: 0 96%;
      transition: background-size 0.6s var(--ease-in-out-quart);
    }
    .email-link:hover {
      background-size: 100% 0.045em;
    }
    /* The row hugs the email (inline-flex); the pill floats just to its
       right, vertically centred, so it never reserves a line below and
       collides with the download button. */
    [data-rsp="mail-row"] {
      position: relative;
    }
    .copied-indicator {
      position: absolute;
      left: 100%;
      top: 50%;
      margin-left: 16px;
      display: inline-block;
      font-family: var(--font), sans-serif;
      font-size: clamp(12px, 1.5vw, 15px);
      font-weight: 600;
      color: #10b981;
      opacity: 0;
      transform: translateY(-50%) scale(0.9);
      transition:
        opacity 0.35s var(--ease-out-back),
        transform 0.35s var(--ease-out-back);
      white-space: nowrap;
      padding: 6px 12px;
      border-radius: 999px;
      background: rgba(16, 185, 129, 0.1);
      border: 1px solid rgba(16, 185, 129, 0.2);
      pointer-events: none;
    }
    .copied-indicator.is-visible {
      opacity: 1;
      transform: translateY(-50%) scale(1);
    }
    .email-copy-icon {
      width: 0.38em;
      height: 0.38em;
      min-width: 24px;
      min-height: 24px;
      opacity: 0.45;
      transition: opacity 0.2s var(--ease-in-out-quart);
      margin-left: 0.12em;
      display: inline-block;
      flex-shrink: 0;
    }
    .email-link:hover .email-copy-icon {
      opacity: 0.85;
    }
    /* ── Badge Tooltips ── */
    .badge-link {
      position: relative;
    }
    .badge-link .custom-tooltip {
      position: absolute;
      bottom: 100%;
      left: 50%;
      transform: translateX(-50%) translateY(-4px);
      background: var(--surface-strong);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      color: var(--text);
      padding: 4px 12px;
      border-radius: 4px;
      font-family: var(--font), sans-serif;
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0;
      white-space: nowrap;
      pointer-events: none;
      opacity: 0;
      border: 1px solid var(--border);
      box-shadow: 0 4px 12px rgba(15, 21, 36, 0.08);
      transition:
        opacity 0.3s cubic-bezier(0.25, 1, 0.5, 1),
        transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
      z-index: 10;
    }
    .badge-link .custom-tooltip::before {
      content: "";
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      border-width: 5px;
      border-style: solid;
      border-color: var(--surface-strong) transparent transparent transparent;
    }
    .badge-link:hover .custom-tooltip,
    .badge-link:focus-visible .custom-tooltip {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
    @media (prefers-reduced-motion: reduce) {
      .fx,
      .hero-l2,
      .w-in,
      .hero-l2 .corner {
        animation: none !important;
        opacity: 1 !important;
        transform: none !important;
      }
      .ticker-track,
      [style*="floatCursor"],
      [style*="pulseDot"] {
        animation: none !important;
      }
      #top::after {
        display: none;
      }
    }
    /* ── Ask AI card — sits at the base of the hero, below the action row ── */
    .ask-ai-slot {
      margin-top: clamp(48px, 9vh, 110px);
    }
    /* Mirrors the canvas landing's .mobile-zone-stepper — always-visible nav
       parked within thumb reach. Scrolls sideways rather than truncating. */
    .mobile-dock {
      display: none;
      position: fixed;
      bottom: 16px;
      left: 16px;
      right: 16px;
      align-items: center;
      justify-content: space-between;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-xl);
      padding: 8px 12px;
      backdrop-filter: blur(12px);
      box-shadow: var(--shadow);
      height: 64px;
      touch-action: none;
      pointer-events: auto;
      z-index: 100;
    }
    .mobile-dock__arrow {
      width: 36px;
      height: 36px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      color: var(--text-soft);
      transition: all 200ms ease;
      background: transparent;
      border: none;
      cursor: pointer;
      flex-shrink: 0;
    }
    .mobile-dock__arrow:active {
      background: var(--surface-muted);
      color: var(--text);
      transform: scale(0.9);
    }
    .mobile-dock__viewport {
      flex: 1;
      overflow: hidden;
      position: relative;
      height: 100%;
      display: flex;
      align-items: center;
      mask-image: linear-gradient(
        to right,
        transparent,
        black 25%,
        black 75%,
        transparent
      );
      -webkit-mask-image: linear-gradient(
        to right,
        transparent,
        black 25%,
        black 75%,
        transparent
      );
    }
    .mobile-dock__track {
      display: flex;
      align-items: center;
      justify-content: center;
      position: absolute;
      width: 100%;
      height: 100%;
      transition: transform 350ms cubic-bezier(0.25, 1, 0.5, 1);
    }
    .mobile-dock__link {
      width: 110px;
      font-family: var(--font), sans-serif;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      white-space: nowrap;
      text-align: center;
      color: var(--text-soft);
      text-decoration: none;
      transition:
        color 300ms ease,
        font-size 300ms ease,
        opacity 300ms ease;
      flex-shrink: 0;
    }
    .mobile-dock__link.is-active {
      color: var(--text);
      font-size: 13px;
      font-weight: 700;
      opacity: 1;
    }
    .mobile-dock__link.is-ghost {
      color: var(--text-soft);
      opacity: 0.6;
    }
    /* Footer social links: text on desktop, icons on mobile. */
    .social-icon {
      display: none;
      width: 20px;
      height: 20px;
    }
    /* The right panel runs out of room before the nav does — shed the
       decorative pill and the resume CTA first (hero and footer both have
       the resume link). */
    @media (max-width: 1100px) {
      [data-rsp="pill"],
      [data-rsp="resume"] {
        display: none !important;
      }
    }
    /* Mobile + tablet: the floating name badge and the location line are
       chrome the header already covers. */
    @media (max-width: 1024px) {
      [data-rsp="hero-eyebrow"],
      [data-rsp="hero-loc"] {
        display: none !important;
      }
    }
    @media (max-width: 900px) {
      [data-rsp="nav"] {
        display: none !important;
      }
      .mobile-dock {
        display: flex;
      }
      #work,
      #experience,
      #gallery,
      #about,
      #contact {
        scroll-margin-top: 96px;
      }
      .ticker .ticker-track > div {
        font-size: 18px !important;
        padding: 16px 10px !important;
        gap: 20px !important;
      }
      .ticker .ticker-track > div > span:not([style*="color"]) {
        width: 6px !important;
        height: 6px !important;
      }
      [data-rsp="case"] {
        position: relative !important;
        top: auto !important;
        left: auto !important;
        right: auto !important;
        grid-template-columns: 1fr !important;
        height: auto !important;
        gap: 32px !important;
        padding: 32px 24px !important;
        opacity: 1 !important;
        transform: none !important;
        margin-bottom: 0;
      }
      #work-cards {
        gap: 16px !important;
      }
      #work-pinned {
        position: relative !important;
        top: auto !important;
        padding: 0 0 24px !important;
      }
      #work-pinned h2 {
        padding-bottom: 0 !important;
      }
      #work {
        padding-top: 56px !important;
        padding-bottom: 56px !important;
      }
      [data-rsp="case"] img {
        max-height: none !important;
      }
      #top {
        padding-top: 96px !important;
        padding-bottom: 56px !important;
      }
      .ask-ai-slot {
        margin-top: 40px;
      }
      #experience,
      #gallery {
        padding-top: 56px !important;
        padding-bottom: 56px !important;
      }
      #about {
        padding-top: 56px !important;
        padding-bottom: 56px !important;
      }
      #contact {
        padding-top: 56px !important;
        /* Clears the fixed dock. */
        padding-bottom: 88px !important;
      }
      [data-rsp="xp-head"] {
        flex-direction: column !important;
        align-items: flex-start !important;
        gap: 8px !important;
        margin-bottom: 40px !important;
      }
      [data-rsp="xp"] {
        grid-template-columns: 1fr !important;
        gap: 12px !important;
        padding: 32px 0 !important;
      }
      [data-rsp="gallery-head"] {
        margin-bottom: 40px !important;
      }
      [data-rsp="about"] {
        grid-template-columns: 1fr !important;
        gap: 40px !important;
      }
      /* Mail, then one row of resume + social icons close under it,
         then the badge set apart. */
      [data-rsp="foot-row"] {
        flex-direction: column !important;
        align-items: flex-start !important;
        gap: 48px !important;
        margin-top: 24px !important;
      }
      [data-rsp="foot-links"] {
        flex-wrap: nowrap !important;
        gap: 12px !important;
      }
      [data-rsp="foot-links"] .btn-primary {
        flex: 0 0 auto;
        white-space: nowrap;
        padding: 12px 20px !important;
      }
      [data-rsp="foot-socials"] {
        flex-wrap: nowrap !important;
        gap: 8px !important;
      }
      .social-label {
        display: none;
      }
      .social-icon {
        display: block;
      }
      .social-link {
        padding: 10px !important;
      }

      .email-link {
        font-size: 32px !important;
      }
      [data-rsp="about"] > div:first-child {
        max-width: 340px;
        margin: 0 auto;
        width: 100%;
      }
      [data-rsp="hero-line"] {
        font-size: clamp(40px, 10.5vw, 104px) !important;
      }
      [data-rsp="hero-h1"] {
        font-size: clamp(40px, 10.5vw, 124px) !important;
      }
    }
  </style>

  <!-- Cursor halo, shared with the canvas landing (styles/glow.css) -->
  <div class="mouse-glow" aria-hidden="true"></div>

  <!-- ══ MASTHEAD — shared chrome with the canvas landing (styles/header.css) ══ -->
  <header class="toolbar">
    <div class="toolbar__panel toolbar__panel--left">
      <div class="toolbar__left">
        <a class="toolbar__branding" href="#top">
          <span class="toolbar__mark">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="46"
              height="28"
              fill="none"
              viewBox="0 0 46 28"
              aria-label="Viknesh Vijayakumar logo"
            >
              <path
                fill="currentColor"
                d="m23.475 4 4.463 3.016v.61L16.362 24.663l-.518.353h-8.73L5.077 28h-.615L0 24.984v-.61L13.84 4h.614l4.462 3.016v.61l-9.83 14.47v2.182L22.861 4h.614Zm18.063 0L46 7.016v.61L34.424 24.663l-.517.353h-8.73L23.138 28h-.614l-4.463-3.016v-.61L31.902 4h.614l4.462 3.016v.61l-9.83 14.47v2.182L40.923 4h.615Z"
              ></path>
            </svg>
          </span>
          <span class="toolbar__identity">
            <span class="toolbar__name">Viknesh Vijayakumar</span>
            <span class="toolbar__role">Lead Product Designer</span>
          </span>
        </a>
        <nav class="header-zone-nav" data-rsp="nav" aria-label="Primary">
          <a class="header-zone-nav__item" href="#work">
            <span class="header-zone-nav__label">Works</span>
            <span class="header-zone-nav__indicator"></span>
          </a>
          <a class="header-zone-nav__item" href="#experience">
            <span class="header-zone-nav__label">Experience</span>
            <span class="header-zone-nav__indicator"></span>
          </a>
          <a class="header-zone-nav__item" href="#gallery">
            <span class="header-zone-nav__label">Other Works</span>
            <span class="header-zone-nav__indicator"></span>
          </a>
          <a class="header-zone-nav__item" href="#about">
            <span class="header-zone-nav__label">About</span>
