    style="display:none;position:fixed;inset:0;z-index:100;flex-direction:column;background:var(--bg);padding:12px var(--pad) 40px"
  >
    <div
      style="display:flex;align-items:center;justify-content:space-between;gap:24px;padding-bottom:12px;border-bottom:1px solid var(--line)"
    >
