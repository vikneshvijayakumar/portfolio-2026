---
// Static footer for case-study pages. Reveal (word-cascade title + rising sub)
// is handled by the shared case-study script, not markup here.
import { toolbarLinks } from "../case-studies/shared";

interface Props {
  title: string;
  sub: string;
}

const { title, sub } = Astro.props;
---

<footer class="case-footer">
  <div class="case-footer__inner">
    <h2 class="case-footer__title">{title}</h2>
    <p class="case-footer__sub">{sub}</p>
    <a class="download-button" href={toolbarLinks.resume} target="_blank" rel="noreferrer">
      Download Resume
    </a>
  </div>
</footer>
