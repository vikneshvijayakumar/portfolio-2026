---
// "Ask an AI" widget — hero action cluster, third and quietest action.
// One source of truth for the prompt; encodeURIComponent does all encoding.
const PROMPT = `I'm evaluating Viknesh Vijayakumar (https://www.viknesh.me) for a senior or lead product design role. Review his portfolio site and tell me three things: his design range, the kind of company and problems where he'd thrive versus where he'd be a poor fit, and what I'd actually get in the first six months if I hired him. Be concrete and cite specific case studies and roles from the site. Don't just sell him. Tell me where the match breaks down too.`;

const q = encodeURIComponent(PROMPT);

const PROVIDERS = [
  {
    id: "chatgpt",
    label: "ChatGPT",
    color: "#10a37f",
    href: `https://chatgpt.com/?q=${q}`,
  },
  {
    id: "gemini",
    label: "Gemini",
    color: "#4285f4",
    href: `https://www.google.com/search?udm=50&aep=11&q=${q}`,
  },
  {
    id: "perplexity",
    label: "Perplexity",
    color: "#20808d",
    href: `https://www.perplexity.ai/search?q=${q}`,
  },
  {
    id: "claude",
    label: "Claude",
    color: "#d97757",
    href: `https://claude.ai/new?q=${q}`,
  },
];

