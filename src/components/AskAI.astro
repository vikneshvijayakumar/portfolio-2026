---

<div class="ask-ai">
  <span class="ask-ai__label">
    <svg
      class="ask-ai__spark"
      viewBox="0 0 24 24"
      width="24"
      height="24"
      fill="currentColor"
      aria-hidden="true"
    >
      <path d="M12 4l1.9 6.1L20 12l-6.1 1.9L12 20l-1.9-6.1L4 12l6.1-1.9L12 4z"
      ></path>
    </svg>
    Short on time? Ask an AI to see if we'd fit
  </span>
  <div class="ask-ai__icons">
    {
      PROVIDERS.map((p, i) => (
        <a
          href={p.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Ask ${p.label} to evaluate this portfolio`}
          class="ask-ai__icon"
          style={`--brand:${p.color};--pop-d:${1.1 + i * 0.09}s`}
        >
          <svg
            viewBox="0 0 24 24"
            width="21"
            height="21"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d={ICONS[p.id]} />
          </svg>
          <span class="ask-ai__tip" aria-hidden="true">
            {p.label} <span class="ask-ai__tip-arrow">↗</span>
          </span>
        </a>
      ))
    }
  </div>
</div>

<style>
  .ask-ai {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px 18px;
    padding: 14px 20px;
    border-radius: 16px;
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    border: 1px solid var(--line);
    box-shadow: 0 12px 28px -18px rgba(15, 21, 36, 0.35);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition:
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }
  .ask-ai:hover {
    border-color: color-mix(in srgb, var(--ac) 30%, var(--line));
    box-shadow: 0 16px 34px -18px rgba(15, 21, 36, 0.45);
  }
  .ask-ai__label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font), sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: var(--muted);
  }
  .ask-ai__spark {
    color: var(--ac);
    animation: askAiTwinkle 3.2s ease-in-out infinite;
  }
  @keyframes askAiTwinkle {
    0%,
    100% {
      transform: scale(1) rotate(0deg);
      opacity: 0.9;
    }
    50% {
      transform: scale(0.72) rotate(45deg);
      opacity: 0.5;
    }
  }
  .ask-ai__icons {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .ask-ai__icon {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    border: 1px solid var(--line);
    background: var(--bg);
    color: var(--muted);
    transform: scale(0);
    animation: askAiPop 0.5s var(--ease-out-back) var(--pop-d) forwards;
    transition:
      color 0.25s cubic-bezier(0.25, 1, 0.5, 1),
      border-color 0.25s cubic-bezier(0.25, 1, 0.5, 1),
      background 0.25s cubic-bezier(0.25, 1, 0.5, 1),
      translate 0.45s cubic-bezier(0.34, 1.56, 0.64, 1),
      rotate 0.45s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.3s ease,
      opacity 0.25s ease;
  }
  @keyframes askAiPop {
    to {
      transform: scale(1);
    }
  }
  .ask-ai__icon svg {
    transition: transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .ask-ai__icon:hover,
  .ask-ai__icon:focus-visible {
    color: var(--brand);
    border-color: color-mix(in srgb, var(--brand) 45%, transparent);
    background: color-mix(in srgb, var(--brand) 8%, var(--bg));
    translate: 0 -3px;
    rotate: -3deg;
    box-shadow: 0 8px 18px -8px
      color-mix(in srgb, var(--brand) 55%, transparent);
  }
  .ask-ai__icon:hover svg,
  .ask-ai__icon:focus-visible svg {
    transform: scale(1.12);
  }
  .ask-ai__icon:active {
    translate: 0 -1px;
    rotate: 0deg;
  }
  /* Non-hovered siblings recede so the hovered provider reads as "chosen" */
  .ask-ai__icons:hover .ask-ai__icon:not(:hover) {
    opacity: 0.45;
  }
  .ask-ai__icon:focus-visible {
    outline: 2px solid var(--ac);
    outline-offset: 2px;
  }
  /* Tooltip */
  .ask-ai__tip {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    translate: -50% 4px;
    padding: 4px 10px;
    border-radius: 6px;
    background: var(--surface-strong, var(--bg));
    border: 1px solid var(--line);
    box-shadow: 0 4px 12px rgba(15, 21, 36, 0.1);
    font-family: var(--font), sans-serif;
    font-size: 11px;
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.25s cubic-bezier(0.25, 1, 0.5, 1),
      translate 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .ask-ai__tip-arrow {
    color: var(--brand);
  }
  .ask-ai__icon:hover .ask-ai__tip,
  .ask-ai__icon:focus-visible .ask-ai__tip {
    opacity: 1;
    translate: -50% 0;
  }
  @media (prefers-reduced-motion: reduce) {
    .ask-ai__icon {
      animation: none;
      transform: none;
      transition: none;
    }
    .ask-ai__spark {
      animation: none;
    }
  }
</style>
