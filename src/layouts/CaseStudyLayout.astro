---
import Layout from './Layout.astro';
import '../case-studies/case-study.css';
import '../case-studies/fx.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;

const siteURL = Astro.site ?? new URL("https://viknesh.me");
const canonicalURL = new URL(Astro.url.pathname, siteURL).href;
const caseStudySchema = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: title,
  headline: title,
  description,
  url: canonicalURL,
  ...(ogImage ? { image: new URL(ogImage, siteURL).href } : {}),
  inLanguage: "en",
  author: {
    "@type": "Person",
    name: "Viknesh Vijayakumar",
    url: siteURL.origin,
    jobTitle: "Lead Product Designer",
  },
  creator: {
    "@type": "Person",
    name: "Viknesh Vijayakumar",
  },
};
---

<Layout {title} {description} {ogImage} pageClass="case-study-page">
  <script type="application/ld+json" is:inline set:html={JSON.stringify(caseStudySchema)} />
  {/* FOUC guard. The shared case-study script adds the reveal classes after
      load, which would flash content visible-then-hidden. This marker + pre-hide
      CSS live in the server HTML so they apply at first paint. Gated on the class
      (JS present) so no-JS crawlers still get visible content, and on
      no-preference because the script skips reveals under reduced motion.
      NOTE: selector lists mirror src/scripts/case-study.ts — keep in sync. */}
  <script is:inline>document.documentElement.classList.add("csfx-armed");</script>
  <style is:inline>
    @media (prefers-reduced-motion: no-preference) {
      .csfx-armed :is(h2.obv3-heading, h2.ps-heading, h2.case-footer__title):not(.csfx-words) {
        opacity: 0;
      }
      .csfx-armed :is(.obv3-principles-cards, .obv3-flow-container, .obv3-feature__helps-list, .ps-audit-grid, .ps-outcomes-grid):not(.in) > * {
        opacity: 0;
        transform: translateY(22px);
      }
      .csfx-armed :is(.obv3-body, .obv3-blockquote, .obv3-subheading, .obv3-section__number, .obv3-feature-card, .obv3-impact-stat, .ps-body, .ps-section__number, .ps-redesign-card__text, .cd-stat, .case-footer__sub):not(.in) {
        opacity: 0;
        transform: translateY(20px);
      }
    }
  </style>
  <main>
    <slot />
  </main>
  {/* Shared fullscreen lightbox for study media (images + expandable videos).
      Inert unless a page has media that opens it. */}
  <div class="cd-lightbox" role="dialog" aria-modal="true" aria-label="Full screen media" aria-hidden="true">
    <button type="button" class="cd-lightbox__close" aria-label="Close full screen view" title="Close full screen view">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
    </button>
    <div class="cd-lightbox__content"></div>
    <button type="button" class="cd-lightbox__nav cd-lightbox__prev" aria-label="Previous image" style="display: none">
      <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
    </button>
    <button type="button" class="cd-lightbox__nav cd-lightbox__next" aria-label="Next image" style="display: none">
      <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6" /></svg>
    </button>
    <div class="cd-lightbox__zoom" hidden>
      <span class="cd-lightbox__counter" style="display: none"></span>
      <button type="button" class="cd-lightbox__zoom-btn" data-zoom="out" aria-label="Zoom out" title="Zoom out">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12" /></svg>
      </button>
      <span class="cd-lightbox__zoom-level" aria-live="polite">100%</span>
      <button type="button" class="cd-lightbox__zoom-btn" data-zoom="in" aria-label="Zoom in" title="Zoom in">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
      </button>
      <button type="button" class="cd-lightbox__zoom-btn" data-zoom="reset" aria-label="Reset zoom" title="Reset zoom">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 3-6.7L3 8" /><path d="M3 3v5h5" /></svg>
      </button>
    </div>
  </div>
  <script>
    import "../scripts/case-study";
  </script>
</Layout>
